{
  "name": "lsqkk-github-io",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "npm run gen:posts-json && npm run gen:rss && npm run sync:public",
    "build": "astro build",
    "postbuild": "node scripts/verify-dist.mjs",
    "preview": "astro preview",
    "gen:posts-json": "node scripts/generate-posts-json.mjs",
    "gen:rss": "node scripts/generate-rss.mjs",
    "sync:public": "node scripts/sync-public.mjs",
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "check:syntax": "node --check assets/js/index.js && node --check assets/js/popup.js && node --check assets/js/message.js && node --check assets/pages/blog/lyb/lyb.js"
  },
  "devDependencies": {
    "astro": "^5.18.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "firebase-admin": "^12.0.0"
  }
}
