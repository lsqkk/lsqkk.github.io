---
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
import LuxuryBackground from "../components/LuxuryBackground.astro";
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - {SITE_TITLE}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/css/404.css" />
    <script is:inline src="/assets/js/cursor-trail.js"></script>
  </head>
  <body class="luxury-body">
    <LuxuryBackground />
    <div class="container">
      <h2>{SITE_TITLE}</h2>
      <div class="emoji">🌌</div>
      <h1>404</h1>
      <p>你似乎来到了没有知识的荒原……</p>

      <div id="searchSuggestions" class="suggestions" style="display: none;">
        <p class="suggestion-title">您要找的是不是：</p>
        <div id="suggestionList" class="suggestion-list"></div>
      </div>

      <div class="buttons">
        <a href="/" class="btn">返回首页</a>
        <a href="/games" class="btn">玩会游戏</a>
      </div>

      <div class="countdown" id="countdown">5 秒后自动回到首页</div>
    </div>

    <script is:inline src="/assets/js/404.js"></script>
    <script is:inline src="/assets/js/disable-right-click.js"></script>
  </body>
</html>
