---
import fs from "node:fs/promises";
import path from "node:path";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";

const navConfigPath = path.join(process.cwd(), "json", "nav.json");
const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const githubLoginUrl = navConfig?.login?.githubUrl || navConfig?.login?.url || "";
const turnstileSiteKey = navConfig?.login?.turnstileSiteKey || "";
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登录 - {SITE_TITLE}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <link rel="stylesheet" href="/assets/css/dark-mode.css" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/pages/login/login.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script is:inline define:vars={{ navConfig, githubLoginUrl, turnstileSiteKey }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__GITHUB_LOGIN_URL__ = githubLoginUrl;
      window.__TURNSTILE_SITE_KEY__ = turnstileSiteKey;
    </script>
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
    <script is:inline src="/assets/js/turnstile-guard.js"></script>
    <script is:inline src="__API_BASE__/api/firebase-config?v=1"></script>
    <script is:inline src="/assets/js/firebase-ready.js"></script>
    <script is:inline src="/assets/js/user-profile.js"></script>
    <script is:inline src="/assets/js/nav.js"></script>
    <script is:inline src="/assets/js/cursor-trail.js"></script>
    <script is:inline src="/assets/pages/login/login.js"></script>
  </head>
  <body class="login-body">
    <div class="login-shell">
      <section class="login-hero">
        <div>
          <p class="login-kicker">Quark Blog</p>
          <h1 class="login-title">登录到夸克博客</h1>
          <p class="login-subtitle">支持 GitHub 与站内账号密码两种方式。</p>
        </div>
        <div class="login-logo">
          <img src={SITE_LOGO_URL} alt="logo" />
        </div>
      </section>

      <main class="login-grid">
        <section class="login-card login-card--github">
          <div class="card-header">
            <h2>GitHub 登录 无需注册</h2>
            <p>推荐，安全快捷。</p>
          </div>
          <div class="risk-banner">
            <strong>安全提示</strong>
            <span>请确认域名为 lsqkk.github.io，谨防钓鱼页面泄露账号信息。</span>
          </div>
          <div class="github-panel">
            <button class="btn primary github-btn" id="githubLoginBtn">
              <i class="fab fa-github"></i>
              使用 GitHub 登录
            </button>
            <p class="helper">点击后将跳转到 GitHub 授权页面。</p>
          </div>
          <div class="login-aside">
            <div class="aside-title">登录后可获得</div>
            <ul>
              <li>评论自动填充昵称与头像，凸显独特身份</li>
              <li>跨设备资料同步，参与互动更方便</li>
              <li>解锁更多功能，畅享博客用户权益</li>
            </ul>
          </div>
        </section>

        <section class="login-card">
          <div class="card-header">
            <h2>账号密码登录</h2>
            <p>适用于不想绑定 GitHub 的用户。</p>
          </div>
          <div class="tab-row">
            <button class="tab-btn active" data-tab="login">登录</button>
            <button class="tab-btn" data-tab="register">注册</button>
          </div>

          <div class="tab-panel active" data-panel="login">
            <div class="mode-row">
              <button class="mode-btn active" data-login-mode="password">账号密码</button>
              <button class="mode-btn" data-login-mode="email">邮箱验证码</button>
            </div>

            <div class="login-mode active" data-login-panel="password">
              <div class="field">
                <label for="loginUsername">账号名</label>
                <input type="text" id="loginUsername" placeholder="仅限英文字母" autocomplete="username" />
              </div>
              <div class="field">
                <label for="loginPassword">密码</label>
                <input type="password" id="loginPassword" placeholder="请输入密码" autocomplete="current-password" />
              </div>
              <div class="field captcha-field">
                <label>安全校验</label>
                <div class="turnstile-row">
            <div id="turnstileContainer" class="turnstile-box" data-turnstile-kind="login"></div>
                </div>
                <div class="helper">通过验证后即可登录，防止脚本攻击。</div>
              </div>
              <div class="action-row">
                <button class="btn primary" id="loginSubmit">登录</button>
                <button class="btn ghost" id="loginReset" type="button">清空</button>
              </div>
            </div>

            <div class="login-mode" data-login-panel="email">
              <div class="field">
                <label for="emailLoginAddress">邮箱</label>
                <input type="email" id="emailLoginAddress" placeholder="name@example.com" autocomplete="email" />
              </div>
              <div class="field">
                <label for="emailLoginCode">邮箱验证码</label>
                <div class="captcha-row">
                  <input type="text" id="emailLoginCode" placeholder="输入验证码" />
                  <button class="btn ghost" id="emailLoginSend" type="button">发送验证码</button>
                </div>
              </div>
              <div class="action-row">
                <button class="btn primary" id="emailLoginSubmit">邮箱登录</button>
              </div>
            </div>

            <div class="forgot-row">
              <button class="link-btn" id="toggleReset" type="button">忘记密码？</button>
            </div>
            <div class="reset-panel" id="resetPanel">
              <div class="field">
                <label for="resetUsername">账号名</label>
                <input type="text" id="resetUsername" placeholder="输入账号名" autocomplete="username" />
                <div class="helper" id="resetEmailHint">验证码将发送至已绑定邮箱</div>
              </div>
              <div class="field">
                <label for="resetCode">邮箱验证码</label>
                <div class="captcha-row">
                  <input type="text" id="resetCode" placeholder="输入验证码" />
                  <button class="btn ghost" id="resetSend" type="button">发送验证码</button>
                </div>
              </div>
              <div class="field">
                <label for="resetPassword">新密码</label>
                <input type="password" id="resetPassword" placeholder="字母+数字，8-20位" />
              </div>
              <div class="field">
                <label for="resetPassword2">确认新密码</label>
                <input type="password" id="resetPassword2" placeholder="再次输入新密码" />
              </div>
              <div class="action-row">
                <button class="btn primary" id="resetSubmit">重置密码</button>
              </div>
              <div class="status-row" id="resetStatus">等待重置</div>
            </div>

            <div class="status-row" id="loginStatus">等待登录</div>
          </div>

          <div class="tab-panel" data-panel="register">
            <div class="field">
              <label for="registerUsername">账号名</label>
              <input type="text" id="registerUsername" placeholder="仅限英文字母，注册后不可修改" />
              <div class="helper">账号名唯一，仅支持英文字母。</div>
              <div class="status-row status-row--inline" id="registerUsernameStatus">等待输入账号名</div>
            </div>
            <div class="field">
              <label for="registerEmail">邮箱（可选）</label>
              <div class="captcha-row">
                <input type="email" id="registerEmail" placeholder="name@example.com" />
                <button class="btn ghost" id="registerEmailSend" type="button">发送验证码</button>
              </div>
              <div class="helper">填写邮箱可用于邮箱登录与找回密码。</div>
            </div>
            <div class="field">
              <label for="registerEmailCode">邮箱验证码</label>
              <input type="text" id="registerEmailCode" placeholder="如未绑定邮箱可留空" />
            </div>
            <div class="field">
              <label for="registerNickname">昵称（可选）</label>
              <input type="text" id="registerNickname" placeholder="不填将自动生成" />
            </div>
            <div class="field">
              <label for="registerPassword">密码</label>
              <input type="password" id="registerPassword" placeholder="字母+数字，8-20位" />
            </div>
            <div class="field">
              <label for="registerPassword2">确认密码</label>
              <input type="password" id="registerPassword2" placeholder="再次输入密码" />
            </div>
            <div class="field captcha-field">
              <label>安全校验</label>
              <div class="turnstile-row">
                <div id="turnstileRegisterContainer" class="turnstile-box" data-turnstile-kind="register"></div>
              </div>
              <div class="helper">注册前需通过人机验证。</div>
            </div>
            <div class="action-row">
              <button class="btn primary" id="registerSubmit">注册账号</button>
              <button class="btn ghost" id="registerReset" type="button">清空</button>
            </div>
            <div class="status-row" id="registerStatus">等待注册</div>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
