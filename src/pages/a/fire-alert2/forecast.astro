---
import FireAlertLayout from "../../../layouts/FireAlertLayout.astro";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---
<FireAlertLayout
  pageTitle={`火险预报 - 山火预警系统 - ${SITE_TITLE}`}
  pageCss="/assets/pages/a/fire-alert2/forecast.css"
  logoIconClass="fas fa-chart-line"
  subtitle="火险预报 - 火险等级预测与蔓延"
  activeNav="forecast"
  headScripts={["https://cdn.jsdelivr.net/npm/chart.js"]}
  bodyScripts={[
    "__API_BASE__/api/keys?names=openweather",
    "/assets/pages/a/fire-alert2/forecast.js",
  ]}
>
  <div class="forecast-grid">
    <div class="dashboard-card card-large">
      <div class="card-header">
        <div class="card-title">
          <div class="card-icon"><i class="fas fa-fire"></i></div>
          未来7天火险预报
        </div>
        <div style="display: flex; gap: 10px;">
          <select id="regionSelect" style="padding: 8px 15px; border-radius: 5px; border: 1px solid var(--card-border); background: rgba(255,255,255,0.1); color: var(--text-light);">
            <option value="north">当前位置</option>
            <option value="west">东北地区</option>
            <option value="east">西南地区</option>
            <option value="south">中国全境</option>
          </select>
        </div>
      </div>
      <div class="chart-container"><canvas id="forecastChart"></canvas></div>
    </div>

    <div class="dashboard-card">
      <div class="card-header">
        <div class="card-title">
          <div class="card-icon"><i class="fas fa-exclamation-triangle"></i></div>
          当前火险等级
        </div>
      </div>
      <div style="text-align: center; padding: 20px 0;">
        <div style="font-size: 48px; font-weight: 700; color: var(--accent-green);">0</div>
        <div style="font-size: 18px; margin-bottom: 15px;">低风险</div>
        <div class="risk-indicator">
          <div class="risk-dot risk-low"></div>
          <span>基于实时气象数据的火险评估</span>
        </div>
      </div>
    </div>

    <div class="dashboard-card card-large">
      <div class="card-header">
        <div class="card-title">
          <div class="card-icon"><i class="fas fa-calendar-alt"></i></div>
          未来三天火险预报
        </div>
      </div>
      <div id="threeDayForecast" class="forecast-days"></div>
    </div>
  </div>
</FireAlertLayout>
