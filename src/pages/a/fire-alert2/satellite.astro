---
import FireAlertLayout from "../../../layouts/FireAlertLayout.astro";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---
<FireAlertLayout
  pageTitle={`卫星监测 - 山火预警系统 - ${SITE_TITLE}`}
  pageCss="/assets/pages/a/fire-alert2/satellite.css"
  logoIconClass="fas fa-satellite"
  subtitle="卫星监测 - 实时火点识别与追踪"
  activeNav="satellite"
  headStyles={["https://cdn.jsdelivr.net/npm/ol@7.3.0/ol.css"]}
  bodyScripts={[
    "https://cdn.jsdelivr.net/npm/ol@7.3.0/dist/ol.js",
    "__API_BASE__/api/tianditu-key",
    "/assets/pages/a/fire-alert2/satellite.js",
  ]}
>
  <div class="map-container">
    <div style="position: relative;">
      <div id="map"></div>
      <div class="map-controls">
        <button class="control-btn active" id="satelliteBtn" onclick="switchLayer('satellite')"><i class="fas fa-satellite"></i> 卫星图</button>
        <button class="control-btn" id="terrainBtn" onclick="switchLayer('terrain')"><i class="fas fa-mountain"></i> 地形图</button>
        <button class="control-btn" id="vectorBtn" onclick="switchLayer('vector')"><i class="fas fa-map"></i> 矢量图</button>
        <button class="control-btn" id="firePointsBtn" onclick="toggleFirePoints()"><i class="fas fa-fire"></i> 火点标记</button>
        <button class="control-btn" id="historyBtn" onclick="toggleHistoryBoundaries()"><i class="fas fa-history"></i> 历史火场</button>
      </div>
    </div>

    <div class="sidebar">
      <div class="sidebar-section">
        <div class="section-title">
          <div class="section-icon"><i class="fas fa-layer-group"></i></div>
          图层控制
        </div>
        <div class="layer-controls">
          <div class="layer-item active" onclick="toggleLayer('firePoints')"><div class="layer-checkbox"></div><span>火点标记</span></div>
          <div class="layer-item active" onclick="toggleLayer('hotspots')"><div class="layer-checkbox"></div><span>热点区域</span></div>
          <div class="layer-item" onclick="toggleLayer('boundaries')"><div class="layer-checkbox"></div><span>行政边界</span></div>
          <div class="layer-item active" onclick="toggleLayer('history')"><div class="layer-checkbox"></div><span>历史火场</span></div>
          <div class="layer-item" onclick="toggleLayer('terrain')"><div class="layer-checkbox"></div><span>地形等高线</span></div>
        </div>
      </div>

      <div class="sidebar-section">
        <div class="section-title">
          <div class="section-icon"><i class="fas fa-fire"></i></div>
          实时火情
        </div>
        <div class="fire-list">
          <div class="fire-item">
            <div class="fire-title"><span>暂无火情</span></div>
          </div>
        </div>

        <div class="stats-grid">
          <div class="stat-card"><div class="stat-label">今日火点</div><div class="stat-value">0</div></div>
          <div class="stat-card"><div class="stat-label">确认火情</div><div class="stat-value">0</div></div>
          <div class="stat-card"><div class="stat-label">监测区域</div><div class="stat-value">8</div></div>
          <div class="stat-card"><div class="stat-label">更新频率</div><div class="stat-value">15min</div></div>
        </div>
      </div>
    </div>
  </div>
</FireAlertLayout>
