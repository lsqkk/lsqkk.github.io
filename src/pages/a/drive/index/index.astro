---
import ShichaBackground from "../../../../components/ShichaBackground.astro";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---

<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="夸克网盘工具，管理员专用的文件上传与分享">
    <title>夸克网盘 - {SITE_TITLE}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png">
    <link rel="stylesheet" href="/assets/css/basic.css">
    <link rel="stylesheet" href="/assets/css/cursor.css">
    <link rel="stylesheet" href="/assets/pages/a/drive/style.css">
    <script is:inline src="/assets/js/cursor-trail.js"></script>
    <script is:inline src="/assets/js/nav.js"></script>
    <script is:inline src="/assets/js/disable-right-click.js"></script>
</head>

<body>
    <ShichaBackground />

    <main class="drive-shell">
        <h1 class="page-title">夸克网盘 / Drive</h1>

        <section class="drive-panel" id="adminPanel">
            <div class="drive-top-row">
                <a class="drive-back-link" href="/a/">返回实验室</a>
                <div class="drive-session" id="adminSession">未登录</div>
            </div>
            <p class="drive-tip">该工具仅管理员可用，登录后可上传任意文件并生成直链。</p>
            <div class="drive-login">
                <input id="adminPassword" type="password" placeholder="管理员密码" autocomplete="current-password">
                <button id="adminLoginBtn" type="button">管理员登录</button>
                <button id="adminLogoutBtn" class="ghost" type="button">退出登录</button>
            </div>
            <div class="drive-status" id="adminStatus">等待登录</div>
        </section>

        <section class="drive-panel admin-only" id="uploadPanel">
            <div class="drive-top-row">
                <div class="drive-title">文件上传</div>
                <div class="drive-local" id="localSyncState">本地记录未同步</div>
            </div>
            <label class="drive-picker" for="fileInput">
                <span>选择文件（支持多选）</span>
                <input id="fileInput" type="file" multiple>
            </label>
            <div class="drive-actions">
                <button id="uploadBtn" type="button">开始上传</button>
                <button id="clearBtn" class="ghost" type="button">清空列表</button>
            </div>
            <div class="drive-status" id="statusText">等待上传</div>
            <div class="drive-progress-wrap">
                <div class="drive-progress" id="progressBar"></div>
            </div>
            <ul class="drive-file-list" id="fileList"></ul>
        </section>

        <section class="drive-panel admin-only">
            <div class="drive-top-row">
                <div class="drive-title">上传结果</div>
                <button id="copyAllBtn" type="button">复制全部直链</button>
            </div>
            <div class="drive-result" id="resultBox"></div>
        </section>

        <section class="drive-panel admin-only">
            <div class="drive-top-row">
                <div class="drive-title">本地记录</div>
                <button id="clearLocalBtn" class="ghost" type="button">清空本地记录</button>
            </div>
            <div class="drive-history" id="historyBox"></div>
        </section>
    </main>

    <script is:inline src="/assets/pages/a/drive/app.js"></script>
</body>

</html>
