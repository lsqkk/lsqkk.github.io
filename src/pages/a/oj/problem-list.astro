---
import OjLayout from "../../../layouts/OjLayout.astro";
import OjSidebar from "../../../components/OjSidebar.astro";
---
<OjLayout
  title="题库列表 - Quark OJ - 夸克博客"
  extraStyles={["/assets/pages/a/oj/style.css"]}
  extraHeadScripts={["/assets/js/nav.js"]}
>
  <script is:inline slot="head">
    function handleSearch() {
      const searchInput = document.getElementById("oj-search-input");
      const searchValue = searchInput.value.trim();
      const url = new URL(window.location.href);
      url.searchParams.delete("page");
      if (searchValue) {
        url.searchParams.set("search", searchValue);
      } else {
        url.searchParams.delete("search");
      }
      window.location.href = url.toString();
    }
  </script>

  <div class="oj-app-wrapper">
    <OjSidebar active="list" />

    <main class="oj-main-content">
      <section class="oj-problem-list-panel glass-card">
        <h2 class="oj-problem-title">题库列表 <span id="search-query-display"></span></h2>
        <p>点击题目名称或 ID 即可跳转到在线判题页面。</p>
        <table class="oj-problem-table">
          <thead>
            <tr>
              <th>状态</th>
              <th>ID</th>
              <th>题目名称</th>
              <th>难度</th>
            </tr>
          </thead>
          <tbody id="oj-problem-list-body">
            <tr>
              <td colspan="4" style="text-align:center;">正在加载题目列表...</td>
            </tr>
          </tbody>
        </table>
      </section>

      <div id="oj-pagination" class="oj-pagination-controls glass-card" style="display: none;">
        <div class="oj-page-size-control">
          <label for="page-size-select">每页显示:</label>
          <select id="page-size-select" class="oj-page-size-select" onchange="changePageSize(this.value)">
            <option value="10">10 题</option>
            <option value="20">20 题</option>
            <option value="30" selected>30 题 (默认)</option>
            <option value="50">50 题</option>
            <option value="100">100 题</option>
          </select>
        </div>
        <div id="oj-page-selector" class="oj-page-selector"></div>
      </div>
    </main>
  </div>

  <script is:inline src="/assets/pages/a/oj/js/utils.js"></script>
  <script is:inline src="/assets/pages/a/oj/js/list.js"></script>
</OjLayout>
