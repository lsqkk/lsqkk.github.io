---
import OjLayout from "../../../../layouts/OjLayout.astro";
import OjSidebar from "../../../../components/OjSidebar.astro";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
const currentYear = new Date().getFullYear();
---
<OjLayout
  title={`Quark OJ - ${SITE_TITLE}`}
  extraStyles={[
    "/assets/pages/a/oj/nav.css",
    "/assets/pages/a/oj/style.css",
    "https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css",
  ]}
  extraHeadScripts={[
    "https://cdn.jsdelivr.net/npm/marked/marked.min.js",
    "https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js",
    "https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js",
    "/assets/js/nav.js",
  ]}
>
  <script is:inline slot="head">
    function handleSearch() {
      const searchInput = document.getElementById("oj-search-input");
      const searchValue = searchInput.value.trim();
      if (searchValue) {
        window.location.href = `problem-list.html?search=${encodeURIComponent(searchValue)}`;
      } else {
        window.location.href = `problem-list.html`;
      }
    }
  </script>
  <style slot="head">
    .oj-home-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    @media (max-width: 768px) { .oj-home-grid { grid-template-columns: 1fr; } }
    .oj-fortune-card { min-height: 250px; text-align: center; display: flex; flex-direction: column; justify-content: center; align-items: center; transition: transform 0.3s, box-shadow 0.3s; }
    .oj-fortune-card:hover { transform: translateY(-5px); box-shadow: 0 8px 15px rgba(0,0,0,0.3); }
    .oj-fortune-status { font-size: 3em; margin: 10px 0; font-weight: bold; text-shadow: 0 0 10px var(--oj-primary-color); }
    .oj-fortune-yi, .oj-fortune-ji { font-size: 1.1em; margin: 5px 0; font-weight: bold; text-shadow: 1px 1px 3px rgba(0,0,0,0.2); }
    .oj-fortune-button { padding: 10px 20px; background-color: #f443367b; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 1.1em; margin-top: 15px; transition: background-color 0.3s, transform 0.1s; }
    .oj-fortune-button:hover:not(:disabled) { background-color: #d32f2fc4; transform: translateY(-1px); }
    .oj-fortune-button:disabled { background-color: #757575; cursor: not-allowed; }
    .oj-random-jump { text-align: center; padding: 40px; background-color: var(--oj-primary-color); cursor: pointer; transition: opacity 0.3s, transform 0.3s; }
    .oj-random-jump:hover { opacity: 0.9; transform: scale(1.02); }
    .oj-random-jump h2 { font-size: 2.2em; margin: 0; color: white; text-shadow: 0 2px 4px rgba(0,0,0,0.4); }
    #announcement-list ul, .oj-stats-panel ul { list-style-type: none; padding-left: 0; margin: 0; }
    #announcement-list li, .oj-stats-panel li { padding: 8px 0; border-bottom: 1px dashed rgba(255,255,255,0.4); }
    #announcement-list li:last-child, .oj-stats-panel li:last-child { border-bottom: none; }
    .oj-stats-panel li a { margin-left: 15px; transition: margin-left 0.3s, border-left 0.3s; display: block; }
  </style>

  <div class="oj-app-wrapper">
    <OjSidebar active="home" />

    <main class="oj-main-content">
      <section class="oj-random-jump glass-card" onclick="jumpToRandomProblem()">
        <h2>随机跳题</h2>
        <p>点击开始一趟未知的刷题之旅</p>
      </section>

      <div class="oj-home-grid">
        <section class="oj-fortune-panel glass-card oj-fortune-card">
          <h3>今日运势</h3>
          <div id="fortune-content">
            <p>抽取你的今日运势，祝你 AC 连连！</p>
            <button id="draw-fortune-btn" class="oj-fortune-button">抽取今日运势</button>
          </div>
        </section>

        <section class="oj-stats-panel glass-card">
          <ul>
            <li><a href="train.html" class="oj-nav-link" style="background: none;">从第一题开始</a></li>
            <li><a href="problem-list.html" class="oj-nav-link" style="background: none;">查看完整题库</a></li>
            <li><a href="discussion.html" class="oj-nav-link" style="background: none;">当前讨论</a></li>
            <li><a href="submission-record.html" class="oj-nav-link" style="background: none;">我的提交记录</a></li>
            <li><a href="problem-list.html" class="oj-nav-link" style="background: none;">题库当前总题目数: <strong id="total-problems">加载中...</strong></a></li>
          </ul>
        </section>
      </div>

      <section class="oj-announcement-panel glass-card">
        <h3>站内公告</h3>
        <div id="announcement-list">
          <ul>
            <li>[2025/12/04] 新主页上线！cos洛谷搞了一个运势</li>
            <li>[2025/12/03] 夸克 OJ 正式上线~ 免注册，直接刷题！</li>
          </ul>
        </div>
      </section>

      <section class="oj-announcement-panel glass-card">
        <h3>版权信息</h3>
        <div id="announcement-list">
          <ul>
            <li>© 2024 - {currentYear} {SITE_TITLE} / 蓝色奇夸克 / 夸克OJ All rights reserved.</li>
            <li>API by: judge0</li>
          </ul>
        </div>
      </section>
    </main>
  </div>

  <script is:inline src="/assets/pages/a/oj/js/utils.js"></script>
  <script is:inline src="/assets/pages/a/oj/js/home.js"></script>
  <script is:inline>
    if (typeof initializeHomePage !== "undefined") {
      initializeHomePage();
    }
  </script>
</OjLayout>
