---
import OjLayout from "../../../layouts/OjLayout.astro";
import OjSidebar from "../../../components/OjSidebar.astro";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---
<OjLayout
  title={`我的提交记录 - Quark OJ - ${SITE_TITLE}`}
  extraStyles={["/assets/pages/a/oj/style.css"]}
  extraHeadScripts={["/assets/js/nav.js"]}
>
  <script is:inline slot="head">
    function handleSearch() {
      const searchInput = document.getElementById("oj-search-input");
      const searchValue = searchInput.value.trim();
      if (searchValue) {
        window.location.href = `problem-list.html?search=${encodeURIComponent(searchValue)}`;
      } else {
        window.location.href = `problem-list.html`;
      }
    }
  </script>

  <div class="oj-app-wrapper">
    <OjSidebar active="record" />

    <main class="oj-main-content">
      <section class="oj-submission-panel glass-card">
        <h2 class="oj-problem-title">我的提交记录</h2>
        <p>这里展示您本地浏览器中存储的每个题目的最新提交结果。</p>
        <table class="oj-problem-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>状态</th>
              <th>运行时间</th>
              <th>内存占用</th>
              <th>提交时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody id="oj-submission-list-body">
            <tr>
              <td colspan="6" style="text-align:center;">正在加载记录...</td>
            </tr>
          </tbody>
        </table>
      </section>
    </main>
  </div>

  <div id="code-modal" class="oj-modal">
    <div class="oj-modal-content glass-card">
      <span class="oj-modal-close" id="code-modal-close">&times;</span>
      <h3 id="modal-title"></h3>
      <p id="modal-lang-info" style="font-style: italic;"></p>
      <pre id="modal-code-display" class="oj-code-pre"></pre>
    </div>
  </div>

  <script is:inline src="/assets/pages/a/oj/js/utils.js"></script>
  <script is:inline src="/assets/pages/a/oj/js/record.js"></script>
</OjLayout>
