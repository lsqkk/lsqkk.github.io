---
import fs from "node:fs/promises";
import path from "node:path";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";

const PROJECT_ROOT = process.cwd();

const indexConfigPath = path.join(PROJECT_ROOT, "json", "index_config.json");
const homeConfigPath = path.join(PROJECT_ROOT, "json", "index.json");
const navConfigPath = path.join(PROJECT_ROOT, "json", "nav.json");
const popupsPath = path.join(PROJECT_ROOT, "json", "popups.json");
const friendsPath = path.join(PROJECT_ROOT, "json", "friends.json");
const postsPath = path.join(PROJECT_ROOT, "posts", "posts.json");
const dynamicMdPath = path.join(PROJECT_ROOT, "assets", "pages", "blog", "dt", "dt.md");
const logMdPath = path.join(PROJECT_ROOT, "assets", "pages", "blog", "log", "log.md");

const indexConfig = JSON.parse(await fs.readFile(indexConfigPath, "utf8"));
const homeConfig = JSON.parse(await fs.readFile(homeConfigPath, "utf8"));
const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const popups = JSON.parse(await fs.readFile(popupsPath, "utf8"));
const friends = JSON.parse(await fs.readFile(friendsPath, "utf8"));
const posts = JSON.parse(await fs.readFile(postsPath, "utf8"));
const dynamicMd = await fs.readFile(dynamicMdPath, "utf8");
const logMd = await fs.readFile(logMdPath, "utf8");
const currentYear = new Date().getFullYear();

function escapeHtml(text: unknown): string {
  return String(text ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function renderSocialLinks(config: any): string {
  const links = Array.isArray(config?.socialLinks) ? config.socialLinks : [];
  return links
    .map(
      (item: any) =>
        `<a href="${escapeHtml(item.url)}" target="_blank"><img src="${escapeHtml(item.icon)}" alt="${escapeHtml(item.alt)}" style="height:30px; width:30px; border-radius: 50%;"></a>`
    )
    .join("");
}

function renderContactLinks(config: any): string {
  const contact = config?.contact || config?.Contact || {};
  const items = [
    {
      key: "email",
      icon: "fas fa-envelope",
      label: "邮箱",
      value: contact.email,
      href: contact.email ? `mailto:${contact.email}` : "",
      target: "",
    },
    {
      key: "phone",
      icon: "fas fa-phone",
      label: "电话",
      value: contact.phone,
      href: contact.phone ? `tel:${contact.phone}` : "",
      target: "",
    },
    {
      key: "cv",
      icon: "fas fa-file-lines",
      label: "简历",
      value: "查看 CV",
      href: contact.cv || "",
      target: "_blank",
    },
    {
      key: "academic",
      icon: "fas fa-graduation-cap",
      label: "学术主页",
      value: "Academic",
      href: contact.academic || "",
      target: "_blank",
    },
  ].filter((item) => item.href);

  if (items.length === 0) return "";

  return `
    <div class="contact-chips" id="contact-chips">
      ${items
        .map(
          (item) => `<a class="contact-chip" href="${escapeHtml(item.href)}"${item.target ? ` target="${item.target}"` : ""}>
            <i class="${item.icon}"></i>
            <span class="contact-label">${escapeHtml(item.label)}</span>
            <span class="contact-value">${escapeHtml(item.value)}</span>
          </a>`
        )
        .join("")}
    </div>
  `;
}

function renderAnnouncement(config: any): string {
  const title = config?.announcement?.title || "";
  const content = config?.announcement?.content || "";
  return `<p style="margin: 0;">${escapeHtml(title)}<br>${content}</p>`;
}

function parseRecentLogs(content: string, maxItems: number) {
  const lines = content.split(/\r?\n/);
  const items: Array<{ type: string; detail: string; date: string }> = [];
  let currentDate = "";
  for (const raw of lines) {
    const line = raw.trim();
    if (!line) continue;
    const dateMatch = line.match(/^#\s+(\d{4}-\d{2}-\d{2})$/);
    if (dateMatch) {
      currentDate = dateMatch[1];
      continue;
    }
    const itemMatch = line.match(/^([\u4e00-\u9fa5A-Za-z]+)\s*-\s*(.+)$/);
    if (!itemMatch) continue;
    items.push({
      type: itemMatch[1].trim(),
      detail: itemMatch[2].trim(),
      date: currentDate,
    });
    if (items.length >= maxItems) break;
  }
  return items;
}

function getLogTagClass(type: string): string {
  if (type === "更新") return "update";
  if (type === "优化") return "optimize";
  if (type === "新增") return "add";
  if (type === "修复") return "fix";
  return "default";
}

function renderRecentLogs(config: any): string {
  const count = typeof config?.showLogNum === "number" ? config.showLogNum : 6;
  const logs = parseRecentLogs(logMd, Math.max(1, count));
  if (logs.length === 0) {
    return `
      <div class="index-sidebar-section">
        <h3>最近更新 Recent Logs</h3>
        <div class="index-announcement"><p style="margin: 0;">暂无更新内容</p></div>
      </div>
    `;
  }
  return `
    <div class="index-sidebar-section">
      <h3>最近更新 Recent Logs</h3>
      <div class="index-log-list">
        ${logs
          .map(
            (log) => `<a class="index-log-item" href="/blog/log">
              <span class="index-log-tag ${getLogTagClass(log.type)}">${escapeHtml(log.type)}</span>
              <span class="index-log-detail">${escapeHtml(log.detail)}</span>
              <span class="index-log-date">${escapeHtml(log.date)}</span>
            </a>`
          )
          .join("")}
      </div>
      <div style="text-align:center; margin: 12px 0;">
        <a href="/blog/log" style="text-decoration: none; color: #007bff; font-size: 0.9em;">查看更多</a>
      </div>
    </div>
  `;
}

function parseMdEntries(content: string) {
  const lines = content.split(/\r?\n/);
  const entries: Array<{ title: string; content: string[]; date: string }> = [];
  let current: { title: string; content: string[]; date: string } | null = null;

  for (const line of lines) {
    if (line.startsWith("# ")) {
      if (current) entries.push(current);
      current = { title: line.replace("# ", "").trim(), content: [], date: "" };
      continue;
    }
    if (!current) continue;
    if (line.startsWith("## 日期：")) {
      current.date = line.replace("## 日期：", "").trim();
      continue;
    }
    if (!line.startsWith("#") && line.trim()) {
      current.content.push(line.trim());
    }
  }
  if (current) entries.push(current);
  return entries;
}

function assembleSections(
  config: Record<string, boolean>,
  renderers: Record<string, () => string>,
  withDivider = false
): string {
  const displayed: string[] = [];
  for (const key of Object.keys(config)) {
    if (!config[key]) continue;
    const renderer = renderers[key];
    if (!renderer) continue;
    const html = renderer().trim();
    if (html) displayed.push(html);
  }
  if (!withDivider) return displayed.join("\n");
  return displayed
    .map((html, idx) => (idx < displayed.length - 1 ? `${html}\n<div class="index-divider"></div>` : html))
    .join("\n");
}

const mainSectionRenderers: Record<string, () => string> = {
  avatar_nickname: () => `
    <a href="posts/about"><img src="assets/img/touxiang.png" alt="头像"
        style="width: 150px; height: 150px; border-radius: 50%; box-shadow: 0 0 15px rgba(0,0,0,0.3); overflow: hidden; position: absolute; top:60px; left: 50%; transform: translate(-50%, -50%); border: 3px solid rgba(255,255,255,0.8);"></a>
    <br><br><br><br><br><br>
    <h1 style="text-align:center; color: rgba(255,255,255,0.9); text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5); font-weight: 600; letter-spacing: 1px;"
      id="Nickname">${escapeHtml(homeConfig.Nickname || "")}</h1>
  `,
  contact_links: () => renderContactLinks(homeConfig),
  social_links: () => `
    <div class="social-icons" style="display: flex; justify-content: center; gap: 15px; margin: 15px 0;"
      id="social-icons-container">${renderSocialLinks(homeConfig)}</div>
  `,
  welcome_section: () => `
    <h2 style="color: #333; text-align: center; margin-bottom: 20px;" id="welcome-title">${escapeHtml(homeConfig.welcomeTitle || "")}</h2>
    <p style="text-align: center; color: #333; line-height: 1.6; max-width: 600px; margin: 0 auto 20px;"
      id="welcome-text">${escapeHtml(homeConfig.welcomeText || "")}</p>
  `,
  typewriter: () => `
    <div class="typewriter-container">
      <div id="typewriter" class="typewriter" style="width: 100%; overflow: hidden;"></div>
    </div>
  `,
  recent_articles: () => `
    <h2 class="recent-header"><a href="/posts">文章 Articles</a> <a href="/posts/rss.xml"><img
      src="/assets/img/rss.svg" style="height: 20px;"></a></h2>
    <div class="recent-posts" style="margin-top: 30px;">
      <div id="recent-posts"></div>
      <a href="/posts" class="more-link">更多</a>
    </div>
  `,
  dynamic_feed: () => `
    <div class="dynamic-feed">
      <h2 class="recent-header"><a href="/blog/dt/">动态 Life Updates</a></h2>
      <div id="dynamic-entries"></div>
      <a href="/blog/dt" class="more-link">更多</a>
    </div>
  `,
};

const sidebarSectionRenderers: Record<string, () => string> = {
  datetime_display: () => `
    <div class="time"> <span id="hours">00</span>:<span id="minutes">00</span>:<span id="seconds">00</span></div>
    <div class="date" id="date">2025年5月14日星期三</div>
  `,
  ip_greeting: () => `<div class="info" id="welcome-info"></div>`,
  greeting_tip: () => `
    <div class="greeting" id="greeting">祝你早安 午安 晚安</div>
    <div class="tip" id="tip">欢迎访问 Quark Blog ~</div>
  `,
  github_promo: () => `
    <div class="index-sidebar-section">
      <div class="github-promo" id="github-promo-card">
        <div class="github-promo-loading">GitHub 数据加载中...</div>
      </div>
    </div>
  `,
  latest_updates: () => renderRecentLogs(homeConfig),
  announcement: () => `
    <div class="index-sidebar-section">
      <h3>公告 Announcement</h3>
      <div class="index-announcement" id="announcement-container">${renderAnnouncement(homeConfig)}</div>
    </div>
  `,
  latest_video: () => `
    <div class="index-sidebar-section">
      <h3>新视频 Latest Video</h3>
      <div id="latest-video-container"
        style="border-radius: 10px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.1);">
        <div style="text-align: center; padding: 20px; color: #AAA;">视频加载中...</div>
      </div>
      <div style="text-align: center; margin: 10px 0;">
        <a href="qtv" style="text-decoration: none; color: #007bff; font-size: 0.9em;">查看更多</a>
      </div>
    </div>
  `,
  comments: () => `
    <div class="index-sidebar-section">
      <h3>留言 Comment</h3>
      <div id="recent-messages">
        <div class="index-announcement"><p style="margin: 0;">留言加载中...</p></div>
      </div>
      <div style="text-align: center; margin: 15px 0;">
        <a href="/blog/lyb" style="text-decoration: none; color: #007bff; font-size: 0.9em;">查看更多 / 写留言</a>
      </div>
    </div>
  `,
  friend_links: () => `
    <div class="index-sidebar-section">
      <h3>友链 Friends</h3>
      <div id="friend-links">
        <div class="index-announcement"><p style="margin: 0;">友链加载中...</p></div>
      </div>
      <div style="text-align: center; margin: 15px 0;font-size: 0.8em;"><a href="/blog/friends"
        style="text-decoration: none; color: #007bff; ">查看更多</a> / 添加友链请
        <a href="/blog/lyb" style="text-decoration: none; color: #007bff; ">在留言板留言</a>
      </div>
    </div>
  `,
};

const footerSectionRenderers: Record<string, () => string> = {
  visitor_stats: () => `
    <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
    共 <span id="busuanzi_value_site_uv" style="color: #007bff; font-weight: bold; font-size: 1.1em;"></span>
    位小伙伴来过 <span id="busuanzi_value_site_pv" style="color: #007bff; font-weight: bold; font-size: 1.1em;"></span> 次
  `,
  copyright_info: () => `
    <br><br>
    <a style="text-align: center; color: #AAA; padding-top: 10px; text-decoration: none;" href="/posts/copyright">© 2024 - ${currentYear} 蓝色奇夸克 | ${SITE_TITLE} All rights reserved.</a>
  `,
  icp_record: () => `
    <br><br>
    <a style="text-align: center; color: #AAA; padding-top: 10px; text-decoration: none;" href="https://icp.gov.moe/?keyword=20250234" target="_blank">
      <img src="assets/img/moe.png" alt="萌ICP备案图标" style="vertical-align: middle; width: 16px; height: 16px; margin-right: 5px;">萌ICP备20250234号
    </a>
  `,
};

const mainContentHtml = assembleSections(indexConfig.main_content, mainSectionRenderers, false);
const sidebarContentHtml = assembleSections(indexConfig.sidebar, sidebarSectionRenderers, true);
const footerContentHtml = assembleSections(indexConfig.footer, footerSectionRenderers, false);

const showDynamicNum = typeof homeConfig.showDynamicNum === "number" ? homeConfig.showDynamicNum : 3;
const dynamicEntries = parseMdEntries(dynamicMd).slice(0, showDynamicNum);
const homePreloaded = {
  homeConfig,
  posts,
  friends,
  dynamicEntries,
};
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>首页 | 蓝色奇夸克のBlog - {SITE_TITLE}</title>
    <link rel="manifest" href="/json/manifest.json" />
    <meta name="description" content={`${SITE_TITLE} | 蓝色奇夸克的个人博客，分享技术、生活与思考。`} />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/css/index.css" />
    <link rel="stylesheet" href="/assets/css/dynamic-gallery.css" />
    <script is:inline define:vars={{ navConfig, homePreloaded, popups }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__HOME_PRELOADED__ = homePreloaded;
      window.__POPUPS_DATA__ = popups;
    </script>
    <script is:inline src="/assets/js/nav.js"></script>
    <script is:inline src="/assets/js/cursor-trail.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
    <script is:inline src="https://unpkg.com/marked@4.0.0/marked.min.js"></script>
    <script is:inline src="/assets/js/dynamic-gallery.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <meta name="referrer" content="never" />
  </head>

  <body>
    <link rel="stylesheet" href="/assets/css/shicha.css" />
    <div class="parallax-bg" id="parallaxBg"></div>
    <script is:inline src="/assets/js/shicha.js"></script>

    <div class="main-layout">
      <div class="main-content" set:html={mainContentHtml}></div>
      <div class="sidebar-index" set:html={sidebarContentHtml}></div>
    </div>
    <div class="footer-container">
      <div class="footer-content" set:html={footerContentHtml}></div>
    </div>
    <br /><br />

    <div id="popup-overlay" class="popup-overlay" style="display: none;">
      <div id="popup-container" class="popup-container">
        <div class="popup-header">
          <h3 id="popup-title"></h3>
          <button id="popup-close" class="popup-close-btn">&times;</button>
        </div>
        <div id="popup-content" class="popup-content"></div>
        <div class="popup-footer">
          <label class="popup-option">
            <input type="checkbox" id="popup-never-show" /> 不再显示
          </label>
          <button id="popup-confirm" class="popup-confirm-btn">知道了</button>
        </div>
      </div>
    </div>

    <div id="celebration-container"></div>

    <script is:inline src="/assets/js/qq-emotion-parser.min.js"></script>
    <script is:inline src="/assets/js/index.js"></script>
    <script is:inline src="/assets/js/popup.js"></script>

    <script is:inline src="https://api.130923.xyz/api/firebase-config?v=1"></script>
    <script is:inline src="/assets/js/message.js"></script>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/assets/js/sw.js").then(function (registration) {
            console.log("Service Worker 注册成功: ", registration);
          }).catch(function (error) {
            console.log("Service Worker 注册失败: ", error);
          });
        });
      }
    </script>

    <script is:inline src="/assets/js/disable-right-click.js"></script>
  </body>
</html>
