---
import LuxuryBackground from "../components/LuxuryBackground.astro";
import fs from "node:fs/promises";
import path from "node:path";
import { SITE_TITLE, SITE_LOGO_URL, SITE_URL, AUTHOR_NAME, AUTHOR_URL } from "@siteConfig";
import {
  escapeHtml,
  parseRecentLogsFromJson,
  getLogTagClass,
  buildDynamicGallery,
  renderPlainLines,
} from "../utils/home-utils";

const PROJECT_ROOT = process.cwd();

const indexConfigPath = path.join(PROJECT_ROOT, "src", "config", "json", "index_config.json");
const homeConfigPath = path.join(PROJECT_ROOT, "src", "config", "json", "index.json");
const navConfigPath = path.join(PROJECT_ROOT, "src", "config", "json", "nav.json");
const popupsPath = path.join(PROJECT_ROOT, "src", "config", "json", "popups.json");
const friendsPath = path.join(PROJECT_ROOT, "src", "config", "json", "friends.json");
const postsPath = path.join(PROJECT_ROOT, "posts", "posts.json");
const dynamicDataPath = path.join(PROJECT_ROOT, "assets", "data", "dt.json");
const logDataPath = path.join(PROJECT_ROOT, "assets", "data", "log.json");
const toolPath = path.join(PROJECT_ROOT, "assets", "pages", "tool", "tool.json");
const gamePath = path.join(PROJECT_ROOT, "assets", "pages", "games", "game.json");
const projectPath = path.join(PROJECT_ROOT, "assets", "pages", "a", "projects.json");

const indexConfig = JSON.parse(await fs.readFile(indexConfigPath, "utf8"));
const homeConfig = JSON.parse(await fs.readFile(homeConfigPath, "utf8"));
const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const popups = JSON.parse(await fs.readFile(popupsPath, "utf8"));
const friends = JSON.parse(await fs.readFile(friendsPath, "utf8"));
const posts = JSON.parse(await fs.readFile(postsPath, "utf8"));
const dtData = JSON.parse(await fs.readFile(dynamicDataPath, "utf8"));
const logData = JSON.parse(await fs.readFile(logDataPath, "utf8"));
const toolData = JSON.parse(await fs.readFile(toolPath, "utf8"));
const gameData = JSON.parse(await fs.readFile(gamePath, "utf8"));
const projectData = JSON.parse(await fs.readFile(projectPath, "utf8"));
const currentYear = new Date().getFullYear();
const footerTitleCn = navConfig?.title?.text || "夸克博客";
const footerTitleEn = navConfig?.title?.en || "Quark Blog";
const footerLogo = navConfig?.logo?.url || SITE_LOGO_URL;


const socialLinks = Array.isArray(homeConfig?.socialLinks) ? homeConfig.socialLinks : [];
const contact = homeConfig?.contact || homeConfig?.Contact || {};
const contactItems = [
  {
    key: "email",
    icon: "envelope",
    label: "邮箱",
    value: contact.email,
    href: contact.email ? `mailto:${contact.email}` : "",
    target: "",
  },
  {
    key: "phone",
    icon: "phone",
    label: "电话",
    value: contact.phone,
    href: contact.phone ? `tel:${contact.phone}` : "",
    target: "",
  },
  {
    key: "cv",
    icon: "file-lines",
    label: "简历",
    value: "查看 CV",
    href: contact.cv || "",
    target: "_blank",
  },
  {
    key: "academic",
    icon: "graduation-cap",
    label: "学术主页",
    value: "Academic",
    href: contact.academic || "",
    target: "_blank",
  },
].filter((item) => item.href);

const announcementTitle = homeConfig?.announcement?.title || "";
const announcementContent = homeConfig?.announcement?.content || "";
const logCount = typeof homeConfig?.showLogNum === "number" ? homeConfig.showLogNum : 6;
const recentLogs = parseRecentLogsFromJson(logData, Math.max(1, logCount));

const mainSectionKeys = Object.keys(indexConfig.main_content || {}).filter(
  (key) => indexConfig.main_content?.[key]
);
const sidebarSectionKeys = Object.keys(indexConfig.sidebar || {}).filter(
  (key) => indexConfig.sidebar?.[key]
);
const footerSectionKeys = Object.keys(indexConfig.footer || {}).filter(
  (key) => indexConfig.footer?.[key]
);
const hasMainSection = (key: string) => mainSectionKeys.includes(key);
const hasSidebarSection = (key: string) => sidebarSectionKeys.includes(key);

const postsTotal = Array.isArray(posts) ? posts.length : 0;
const dynamicTotal = dtData.length;
const toolsTotal = Array.isArray(toolData?.categories)
  ? toolData.categories.reduce((sum: number, cat: any) => sum + (cat.tools?.length || 0), 0)
  : 0;
const gamesTotal = ["multiplayer", "singlePlayer", "classic"].reduce((sum, key) => {
  const list = Array.isArray(gameData?.[key]) ? gameData[key] : [];
  return sum + list.length;
}, 0);
const projectsTotal = Array.isArray(projectData?.categories)
  ? projectData.categories.reduce((sum: number, cat: any) => sum + (cat.projects?.length || 0), 0)
  : 0;

const showDynamicNum = typeof homeConfig.showDynamicNum === "number" ? homeConfig.showDynamicNum : 3;
const dynamicEntries = dtData.slice(0, showDynamicNum).map((entry: any) => ({
  id: entry.id,
  title: entry.title,
  date: entry.date,
  content: (entry.content || "").split("\n"),
  images: entry.images || [],
}));
const showPostNum = typeof homeConfig.showPostNum === "number" ? homeConfig.showPostNum : 3;
const recentPosts = posts.slice(0, showPostNum);
const homePreloaded = {
  homeConfig,
  posts,
  friends,
  dynamicEntries,
  footerStats: {
    postsTotal,
    dynamicTotal,
    toolsTotal,
    projectsTotal,
    gamesTotal,
  },
};

  // SVG icon helper — inline SVGs eliminate Font Awesome CDN dependency
  const icon = (name) => {
    const svgs = {
      envelope: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="svg-inline" fill="currentColor"><path d="M256 352c-16.53 0-33.06-5.422-47.16-16.41L0 173.2V400C0 426.5 21.49 448 48 448h416c26.51 0 48-21.49 48-48V173.2l-208.8 162.5C289.1 346.6 272.5 352 256 352zM16.29 145.3l212.2 165.1c16.19 12.6 38.87 12.6 55.06 0l212.2-165.1C505.1 137.3 512 125 512 112C512 85.49 490.5 64 464 64h-416C21.49 64 0 85.49 0 112C0 125 6.01 137.3 16.29 145.3z"/></svg>',
      phone: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="svg-inline" fill="currentColor"><path d="M511.2 387l-23.25 100.8c-3.266 14.25-15.79 24.22-30.46 24.22C205.2 512 0 306.8 0 54.5c0-14.66 9.969-27.2 24.22-30.45l100.8-23.25C139.7-2.602 154.7 5.018 160.8 18.92l46.52 108.5c5.438 12.78 1.77 27.67-8.98 36.45L144.5 207.1c33.98 69.22 90.26 125.5 159.5 159.5l44.08-53.8c8.688-10.78 23.69-14.51 36.47-8.975l108.5 46.51C506.1 357.2 514.6 372.4 511.2 387z"/></svg>',
      "file-lines": '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" class="svg-inline" fill="currentColor"><path d="M256 0v128h128L256 0zM224 128L224 0H48C21.49 0 0 21.49 0 48v416C0 490.5 21.49 512 48 512h288c26.51 0 48-21.49 48-48V160h-127.1C238.3 160 224 145.7 224 128zM272 416h-160C103.2 416 96 408.8 96 400C96 391.2 103.2 384 112 384h160c8.836 0 16 7.162 16 16C288 408.8 280.8 416 272 416zM272 352h-160C103.2 352 96 344.8 96 336C96 327.2 103.2 320 112 320h160c8.836 0 16 7.162 16 16C288 344.8 280.8 352 272 352zM288 272C288 280.8 280.8 288 272 288h-160C103.2 288 96 280.8 96 272C96 263.2 103.2 256 112 256h160C280.8 256 288 263.2 288 272z"/></svg>',
      "graduation-cap": '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" class="svg-inline" fill="currentColor"><path d="M623.1 136.9l-282.7-101.2c-13.73-4.91-28.7-4.91-42.43 0L16.05 136.9C6.438 140.4 0 149.6 0 160s6.438 19.65 16.05 23.09L76.07 204.6c-11.89 15.8-20.26 34.16-24.55 53.95C40.05 263.4 32 274.8 32 288c0 9.953 4.814 18.49 11.94 24.36l-24.83 149C17.48 471.1 25 480 34.89 480H93.11c9.887 0 17.41-8.879 15.78-18.63l-24.83-149C91.19 306.5 96 297.1 96 288c0-10.29-5.174-19.03-12.72-24.89c4.252-17.76 12.88-33.82 24.94-47.03l190.6 68.23c13.73 4.91 28.7 4.91 42.43 0l282.7-101.2C633.6 179.6 640 170.4 640 160S633.6 140.4 623.1 136.9zM351.1 314.4C341.7 318.1 330.9 320 320 320c-10.92 0-21.69-1.867-32-5.555L142.8 262.5L128 405.3C128 446.6 213.1 480 320 480c105.1 0 192-33.4 192-74.67l-14.78-142.9L351.1 314.4z"/></svg>',
      rss: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="svg-inline" fill="currentColor"><path d="M25.57 176.1C12.41 175.4 .9117 185.2 .0523 198.4s9.173 24.65 22.39 25.5c120.1 7.875 225.7 112.7 233.6 233.6C256.9 470.3 267.4 480 279.1 480c.5313 0 1.062-.0313 1.594-.0625c13.22-.8438 23.25-12.28 22.39-25.5C294.6 310.3 169.7 185.4 25.57 176.1zM32 32C14.33 32 0 46.31 0 64s14.33 32 32 32c194.1 0 352 157.9 352 352c0 17.69 14.33 32 32 32s32-14.31 32-32C448 218.6 261.4 32 32 32zM63.1 351.9C28.63 351.9 0 380.6 0 416s28.63 64 63.1 64s64.08-28.62 64.08-64S99.37 351.9 63.1 351.9z"/></svg>',
      folder: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="svg-inline" fill="currentColor"><path d="M464 96h-192l-64-64h-160C21.5 32 0 53.5 0 80V160h512V144C512 117.5 490.5 96 464 96zM0 432C0 458.5 21.5 480 48 480h416c26.5 0 48-21.5 48-48V192H0V432z"/></svg>',
      tag: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="svg-inline" fill="currentColor"><path d="M48 32H197.5C214.5 32 230.7 38.74 242.7 50.75L418.7 226.7C443.7 251.7 443.7 292.3 418.7 317.3L285.3 450.7C260.3 475.7 219.7 475.7 194.7 450.7L18.75 274.7C6.743 262.7 0 246.5 0 229.5V80C0 53.49 21.49 32 48 32L48 32zM112 176C129.7 176 144 161.7 144 144C144 126.3 129.7 112 112 112C94.33 112 80 126.3 80 144C80 161.7 94.33 176 112 176z"/></svg>',
      calendar: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" class="svg-inline" fill="currentColor"><path d="M152 64H296V24C296 10.75 306.7 0 320 0C333.3 0 344 10.75 344 24V64H384C419.3 64 448 92.65 448 128V448C448 483.3 419.3 512 384 512H64C28.65 512 0 483.3 0 448V128C0 92.65 28.65 64 64 64H104V24C104 10.75 114.7 0 128 0C141.3 0 152 10.75 152 24V64zM48 448C48 456.8 55.16 464 64 464H384C392.8 464 400 456.8 400 448V192H48V448z"/></svg>',
    };
    return svgs[name] || "";
  };
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{SITE_TITLE} — 蓝色奇夸克</title>
    <link rel="manifest" href="/json/manifest.json" />
    <meta name="description" content={`${SITE_TITLE} | 蓝色奇夸克的个人博客，分享技术、生活与思考。`} />
    <meta property="og:image" content={SITE_LOGO_URL} />
    <link rel="alternate" type="application/rss+xml" title="夸克博客 RSS" href="/posts/rss.xml" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/css/index.css" />
    <link rel="stylesheet" href="/assets/css/dynamic-gallery.css" />
    <script is:inline define:vars={{ navConfig, homePreloaded, popups }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__HOME_PRELOADED__ = homePreloaded;
      window.__POPUPS_DATA__ = popups;
    </script>
    <script is:inline src="/assets/js/cursor-trail.js"></script>
    <script is:inline src="https://unpkg.com/marked@4.0.0/marked.min.js"></script>
    <script is:inline src="/assets/js/dynamic-gallery.js"></script>
    <meta name="referrer" content="never" />
  </head>

  <body class="home-page luxury-body">
    <script is:inline src="/assets/js/nav.js"></script>
    <LuxuryBackground />

    <div class="main-layout">
      <main class="main-content">
        {(hasMainSection("avatar_nickname") ||
          hasMainSection("welcome_section") ||
          hasMainSection("typewriter") ||
          hasMainSection("contact_links") ||
          hasMainSection("social_links")) && (
            <section class="home-block home-panel intro-combo-panel">
              {hasMainSection("avatar_nickname") && (
                <div class="intro-hero hero-section">
                  <a class="hero-avatar-link" href="/posts/about">
                    <img class="hero-avatar" src="/assets/img/touxiang.png" alt="头像" data-skeleton-img />
                  </a>
                  <h1 class="hero-title" id="Nickname">{escapeHtml(homeConfig.Nickname || "")}</h1>
                </div>
              )}
              {hasMainSection("welcome_section") && (
                <div class="intro-copy intro-section">
                  <h2 class="welcome-title" id="welcome-title">{escapeHtml(homeConfig.welcomeTitle || "")}</h2>
                  <p class="welcome-text" id="welcome-text">{escapeHtml(homeConfig.welcomeText || "")}</p>
                </div>
              )}
              {hasMainSection("typewriter") && (
                <div class="intro-type typewriter-section">
                  <div class="typewriter-container">
                    <div id="typewriter" class="typewriter"></div>
                  </div>
                </div>
              )}
              {(hasMainSection("contact_links") || hasMainSection("social_links")) && (
                <div class="intro-links">
                  {hasMainSection("contact_links") && contactItems.length > 0 && (
                    <div class="contact-chips" id="contact-chips">
                      {contactItems.map((item) => (
                        <a class="contact-chip" href={escapeHtml(item.href)} target={item.target || undefined}>
                          <span class="contact-icon"><Fragment set:html={icon(item.icon)} /></span>
                          <span class="contact-text">
                            <span class="contact-label">{escapeHtml(item.label)}</span>
                            <span class="contact-value">{escapeHtml(item.value)}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                  )}
                  {hasMainSection("social_links") && (
                    <div class="social-icons" id="social-icons-container">
                      {socialLinks.map((item: any) => (
                        <a class="social-link" href={escapeHtml(item.url)} target="_blank" rel="noreferrer">
                          <img class="social-link-icon" src={escapeHtml(item.icon)} alt={escapeHtml(item.alt)} />
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              )}
            </section>
        )}
        {hasMainSection("recent_articles") && (
            <section class="home-block home-panel content-section">
              <div class="section-head recent-header">
                <h2 class="section-title-link">
                  <a href="/posts">文章 Articles</a>
                </h2>
                <a href="/posts/rss.xml" class="rss-link" aria-label="RSS订阅">
                  <Fragment set:html={icon("rss")} />
                </a>
              </div>
              <div id="recent-posts" class="content-list recent-posts" data-preloaded="true">
                {recentPosts.map((post: any) => (
                  <article class="post-item post-item-link content-row" data-href={`/posts/${post.file.replace(".md", "")}`}>
                    <div class="post-item-body">
                      <div class="post-title">{escapeHtml(post.title)}</div>
                      <div class="post-date">{escapeHtml(post.date)}</div>
                      <div class="post-tags">
                        <span class="post-tag read-time">
                          {String(post.wordCount || 0)}字·{Math.ceil((post.wordCount || 0) / 400)}min
                        </span>
                        {(post.columns || []).map((column: string) => (
                          <a class="post-tag post-tag-col tag-link" href={`/posts/${encodeURIComponent(column)}`}>
                            <Fragment set:html={icon("folder")} />{column}
                          </a>
                        ))}
                        {(post.tags || ["未分类"]).map((tag: string) => (
                          <a class="post-tag tag-link" href={`/posts?tag=${encodeURIComponent(tag)}`}>
                            <Fragment set:html={icon("tag")} />{tag}
                          </a>
                        ))}
                      </div>
                    </div>
                    {post.cover && (
                      <div class="post-cover-wrap">
                        <img class="post-cover" src={post.cover} alt={post.title} loading="lazy" decoding="async" referrerpolicy="no-referrer" data-skeleton-img />
                      </div>
                    )}
                  </article>
                ))}
              </div>
              <a href="/posts" class="more-link">更多</a>
            </section>
        )}
        {hasMainSection("dynamic_feed") && (
            <section class="home-block home-panel content-section dynamic-feed">
              <div class="section-head recent-header">
                <h2 class="section-title-link"><a href="/blog/dt/">动态 Life Updates</a></h2>
              </div>
              <div id="dynamic-entries" class="content-list dynamic-list" data-preloaded="true">
                {dynamicEntries.map((entry, index) => {
                  const dynamicId = entry.id || `${entry.date || "undated"}-${index + 1}`;
                  const rawContent = (entry.content || []).join("\n");
                  const htmlContent = renderPlainLines(rawContent);
                  const galleryHtml = buildDynamicGallery(entry.images || [], `pre-${dynamicId}`);
                  return (
                    <article class="dynamic-card content-row" data-dynamic-id={dynamicId} data-dynamic-link={`/blog/dt/${dynamicId}`}>
                      <div class="dynamic-title">{escapeHtml(entry.title)}</div>
                      {entry.date && (
                        <div class="dynamic-date">
                          <Fragment set:html={icon("calendar")} />{escapeHtml(entry.date)}
                        </div>
                      )}
                      <div
                        class="dynamic-content"
                        data-raw-md={escapeHtml(rawContent)}
                        set:html={htmlContent}
                      ></div>
                      {galleryHtml && <Fragment set:html={galleryHtml} />}
                      <div class="dynamic-entry-footer">
                        <div class="dynamic-entry-actions">
                          <button class="dynamic-like-btn" type="button" data-dynamic-like-btn>点赞 (0)</button>
                          <a class="dynamic-detail-link" href={`/blog/dt/${dynamicId}`}>查看详情</a>
                        </div>
                        <div class="dynamic-entry-stats">
                          <span>点赞 <span data-dynamic-like-count>0</span></span>
                          <span>评论 <span data-dynamic-comment-count>0</span></span>
                        </div>
                      </div>
                      <div class="dynamic-comment-preview" data-dynamic-comment-preview>
                        <div class="dynamic-preview-empty"></div>
                      </div>
                    </article>
                  );
                })}
              </div>
              <a href="/blog/dt" class="more-link">更多</a>
            </section>
        )}
      </main>
      <aside class="sidebar-index">
        {(hasSidebarSection("datetime_display") ||
          hasSidebarSection("greeting_tip") ||
          hasSidebarSection("ip_greeting")) && (
            <section class="index-sidebar-section sidebar-panel sidebar-welcome-panel">
              {hasSidebarSection("datetime_display") && (
                <div class="sidebar-welcome-block sidebar-time-panel">
                  <div class="time"> <span id="hours">00</span>:<span id="minutes">00</span>:<span id="seconds">00</span></div>
                  <div class="date" id="date">2025年5月14日星期三</div>
                </div>
              )}
              {hasSidebarSection("greeting_tip") && (
                <div class="sidebar-welcome-block">
                  <div class="greeting" id="greeting">祝你早安 午安 晚安</div>
                  <div class="tip" id="tip">欢迎访问 Quark Blog ~</div>
                </div>
              )}
              {hasSidebarSection("ip_greeting") && (
                <div class="sidebar-welcome-block">
                  <div class="info" id="welcome-info"></div>
                </div>
              )}
            </section>
        )}
        {hasSidebarSection("online_preview") && (
            <section class="index-sidebar-section sidebar-panel">
              <h3 class="sidebar-title online-preview-title">在线 Online <span class="online-preview-count" id="online-preview-count">0</span></h3>
              <div id="online-preview">
                <div class="index-announcement"><p class="index-announcement-text"></p></div>
              </div>
              <div class="sidebar-more-wrap"><a href="/a/online" class="sidebar-more-link">查看在线</a></div>
            </section>
        )}
        {hasSidebarSection("github_promo") && (
            <section class="index-sidebar-section sidebar-panel">
              <div class="github-promo" id="github-promo-card">
                <div class="github-promo-loading"></div>
              </div>
            </section>
        )}
        {hasSidebarSection("latest_updates") && (
            <section class="index-sidebar-section sidebar-panel">
              <h3 class="sidebar-title">最近更新 Recent Logs</h3>
              {recentLogs.length === 0 ? (
                <div class="index-announcement"><p class="index-announcement-text">暂无更新内容</p></div>
              ) : (
                <>
                  <div class="index-log-list">
                    {recentLogs.map((log) => (
                      <a class="index-log-item" href="/blog/log">
                        <span class={`index-log-tag ${getLogTagClass(log.type)}`}>{escapeHtml(log.type)}</span>
                        <span class="index-log-detail">{escapeHtml(log.detail)}</span>
                        <span class="index-log-date">{escapeHtml(log.date)}</span>
                      </a>
                    ))}
                  </div>
                  <div class="sidebar-more-wrap"><a href="/blog/log" class="sidebar-more-link">查看更多</a></div>
                </>
              )}
            </section>
        )}
        {hasSidebarSection("announcement") && (
            <section class="index-sidebar-section sidebar-panel">
              <h3 class="sidebar-title">公告 Announcement</h3>
              <div class="index-announcement" id="announcement-container">
                <div class="index-announcement-text">
                  <span class="index-announcement-title">{escapeHtml(announcementTitle)}</span>
                  <span class="index-announcement-body" set:html={announcementContent}></span>
                </div>
              </div>
            </section>
        )}
        {hasSidebarSection("latest_video") && (
            <section class="index-sidebar-section sidebar-panel">
              <h3 class="sidebar-title">新视频 Latest Video</h3>
              <div id="latest-video-container" class="latest-video-container">
                <div class="loading-placeholder"></div>
              </div>
              <div class="sidebar-more-wrap"><a href="qtv" class="sidebar-more-link">查看更多</a></div>
            </section>
        )}
        {hasSidebarSection("comments") && (
            <section class="index-sidebar-section sidebar-panel">
              <h3 class="sidebar-title">留言 Comment</h3>
              <div id="recent-messages">
                <div class="index-announcement"><p class="index-announcement-text"></p></div>
              </div>
              <div class="sidebar-more-wrap"><a href="/blog/lyb" class="sidebar-more-link">查看更多 / 写留言</a></div>
            </section>
        )}
        {hasSidebarSection("friend_links") && (
            <section class="index-sidebar-section sidebar-panel">
              <h3 class="sidebar-title">友链 Friends</h3>
              <div id="friend-links" data-preloaded="true">
                {Array.isArray(friends) && friends.length > 0 ? (
                  friends.map((friend: any) => (
                    <a href={friend.url} target="_blank" class="friend-link-item">
                      <div class="friend-icon-wrap">
                        <img src={friend.icon} alt={friend.nickname} class="friend-icon" onerror="this.src='assets/img/logo_blue.png'" data-skeleton-img />
                      </div>
                      <div class="friend-info">
                        <div class="friend-nickname">{escapeHtml(friend.nickname)}</div>
                        <div class="friend-describe">{escapeHtml(friend.describe)}</div>
                      </div>
                    </a>
                  ))
                ) : (
                  <div class="index-announcement"><p class="index-announcement-text">暂无友链</p></div>
                )}
              </div>
              <div class="sidebar-more-wrap sidebar-more-wrap-sm">
                <a href="/blog/friends" class="sidebar-more-link">查看更多</a> / 添加友链请
                <a href="/blog/lyb" class="sidebar-more-link">在留言板留言</a>
              </div>
            </section>
        )}
      </aside>
    </div>
    <div class="footer-container">
      <footer class="footer-card">
        <div class="footer-head">
          <div>
            <div class="footer-kicker">{footerTitleEn}</div>
            <div class="footer-title">
              <span class="footer-logo-wrap"><img class="footer-logo" src={footerLogo} alt="logo" data-skeleton-img /></span>
              <span>{footerTitleCn}</span>
            </div>
          </div>
          <div class="footer-meta">
            {footerSectionKeys.map((key) => (
              key === "visitor_stats" ? (
                <>
                  <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
                  <div class="footer-meta-item">
                    访客 <span id="busuanzi_value_site_uv" class="footer-highlight"></span>
                    · 来过 <span id="busuanzi_value_site_pv" class="footer-highlight"></span> 次
                  </div>
                </>
              ) : key === "copyright_info" ? (
                <a class="footer-link footer-meta-item" href="/posts/copyright">
                  © 2024 - {currentYear} 蓝色奇夸克 | {SITE_TITLE} All rights reserved.
                </a>
              ) : key === "icp_record" ? (
                <a class="footer-link footer-meta-item" href="https://icp.gov.moe/?keyword=20250234" target="_blank">
                  <img src="assets/img/moe.png" alt="萌ICP备案图标" class="footer-record-icon" data-skeleton-img>萌ICP备20250234号
                </a>
              ) : null
            ))}
          </div>
        </div>
        <div class="footer-stats-grid" id="footer-static-stats">
          <a class="footer-stat footer-stat-link" href="/posts">
            <div class="footer-stat-label">文章总数</div>
            <div class="footer-stat-value" id="footer-post-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/blog/dt">
            <div class="footer-stat-label">动态总数</div>
            <div class="footer-stat-value" id="footer-dynamic-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/tool">
            <div class="footer-stat-label">工具 / 实验</div>
            <div class="footer-stat-value" id="footer-tool-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/games">
            <div class="footer-stat-label">游戏总数</div>
            <div class="footer-stat-value" id="footer-game-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/a/online">
            <div class="footer-stat-label">注册用户</div>
            <div class="footer-stat-value" id="footer-user-total">--</div>
          </a>
          <a class="footer-stat footer-stat-link" href={AUTHOR_URL} target="_blank" rel="noreferrer">
            <div class="footer-stat-label">开源项目</div>
            <div class="footer-stat-value" id="footer-project-total">--</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/blog/log">
            <div class="footer-stat-label">今日 Commit</div>
            <div class="footer-stat-value" id="footer-commit-total">--</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/blog/log">
            <div class="footer-stat-label">安全运行</div>
            <div class="footer-stat-value" id="footer-running-days">--</div>
            <div class="footer-stat-meta">自 2025-01-31 起</div>
          </a>
        </div>
      </footer>
    </div>
    <br /><br />

    <div id="popup-overlay" class="popup-overlay" style="display: none;">
      <div id="popup-container" class="popup-container">
        <div class="popup-header">
          <h3 id="popup-title"></h3>
          <button id="popup-close" class="popup-close-btn">&times;</button>
        </div>
        <div id="popup-content" class="popup-content"></div>
        <div class="popup-footer">
          <label class="popup-option">
            <input type="checkbox" id="popup-never-show" /> 不再显示
          </label>
          <button id="popup-confirm" class="popup-confirm-btn">知道了</button>
        </div>
      </div>
    </div>

    <div id="celebration-container"></div>

    <script is:inline src="/assets/js/qq-emotion-parser.min.js"></script>
    <script is:inline src="/assets/js/index.js"></script>
    <script is:inline src="/assets/js/popup.js"></script>

    <script is:inline src="__API_BASE__/api/firebase-config?v=1"></script>
    <script is:inline src="/assets/js/firebase-ready.js"></script>
    <script is:inline src="/assets/js/comment-shared.js"></script>
    <script is:inline src="/assets/js/comment-render-shared.js"></script>
    <script is:inline src="/assets/js/message.js"></script>
    <script is:inline src="/assets/js/dynamic-interactions.js"></script>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/assets/js/sw.js").catch(function () {
            // Service Worker registration failed silently
          });
        });
      }
    </script>

  </body>
</html>







