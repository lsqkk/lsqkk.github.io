---
import fs from "node:fs/promises";
import path from "node:path";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
import { parseDynamicEntries } from "../utils/dynamic-entries";

const PROJECT_ROOT = process.cwd();

const indexConfigPath = path.join(PROJECT_ROOT, "json", "index_config.json");
const homeConfigPath = path.join(PROJECT_ROOT, "json", "index.json");
const navConfigPath = path.join(PROJECT_ROOT, "json", "nav.json");
const popupsPath = path.join(PROJECT_ROOT, "json", "popups.json");
const friendsPath = path.join(PROJECT_ROOT, "json", "friends.json");
const postsPath = path.join(PROJECT_ROOT, "posts", "posts.json");
const dynamicMdPath = path.join(PROJECT_ROOT, "assets", "md", "dt.md");
const logMdPath = path.join(PROJECT_ROOT, "assets", "md", "log.md");
const toolPath = path.join(PROJECT_ROOT, "assets", "pages", "tool", "tool.json");
const gamePath = path.join(PROJECT_ROOT, "assets", "pages", "games", "game.json");
const projectPath = path.join(PROJECT_ROOT, "assets", "pages", "a", "projects.json");

const indexConfig = JSON.parse(await fs.readFile(indexConfigPath, "utf8"));
const homeConfig = JSON.parse(await fs.readFile(homeConfigPath, "utf8"));
const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const popups = JSON.parse(await fs.readFile(popupsPath, "utf8"));
const friends = JSON.parse(await fs.readFile(friendsPath, "utf8"));
const posts = JSON.parse(await fs.readFile(postsPath, "utf8"));
const dynamicMd = await fs.readFile(dynamicMdPath, "utf8");
const logMd = await fs.readFile(logMdPath, "utf8");
const toolData = JSON.parse(await fs.readFile(toolPath, "utf8"));
const gameData = JSON.parse(await fs.readFile(gamePath, "utf8"));
const projectData = JSON.parse(await fs.readFile(projectPath, "utf8"));
const currentYear = new Date().getFullYear();
const footerTitleCn = navConfig?.title?.text || "夸克博客";
const footerTitleEn = navConfig?.title?.en || "Quark Blog";
const footerLogo = navConfig?.logo?.url || SITE_LOGO_URL;

function escapeHtml(text: unknown): string {
  return String(text ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function renderSocialLinks(config: any): string {
  const links = Array.isArray(config?.socialLinks) ? config.socialLinks : [];
  return links
    .map(
      (item: any) =>
        `<a class="social-link" href="${escapeHtml(item.url)}" target="_blank" rel="noreferrer">
          <img class="social-link-icon" src="${escapeHtml(item.icon)}" alt="${escapeHtml(item.alt)}">
        </a>`
    )
    .join("");
}

function renderContactLinks(config: any): string {
  const contact = config?.contact || config?.Contact || {};
  const items = [
    {
      key: "email",
      icon: "fas fa-envelope",
      label: "邮箱",
      value: contact.email,
      href: contact.email ? `mailto:${contact.email}` : "",
      target: "",
    },
    {
      key: "phone",
      icon: "fas fa-phone",
      label: "电话",
      value: contact.phone,
      href: contact.phone ? `tel:${contact.phone}` : "",
      target: "",
    },
    {
      key: "cv",
      icon: "fas fa-file-lines",
      label: "简历",
      value: "查看 CV",
      href: contact.cv || "",
      target: "_blank",
    },
    {
      key: "academic",
      icon: "fas fa-graduation-cap",
      label: "学术主页",
      value: "Academic",
      href: contact.academic || "",
      target: "_blank",
    },
  ].filter((item) => item.href);

  if (items.length === 0) return "";

  return `
    <div class="contact-chips" id="contact-chips">
      ${items
        .map(
          (item) => `<a class="contact-chip" href="${escapeHtml(item.href)}"${item.target ? ` target="${item.target}"` : ""}>
            <i class="${item.icon}"></i>
            <span class="contact-label">${escapeHtml(item.label)}</span>
            <span class="contact-value">${escapeHtml(item.value)}</span>
          </a>`
        )
        .join("")}
    </div>
  `;
}

function renderAnnouncement(config: any): string {
  const title = config?.announcement?.title || "";
  const content = config?.announcement?.content || "";
  return `
    <div class="index-announcement-text">
      <span class="index-announcement-title">${escapeHtml(title)}</span>
      <span class="index-announcement-body">${content}</span>
    </div>
  `;
}

function parseRecentLogs(content: string, maxItems: number) {
  const lines = content.split(/\r?\n/);
  const items: Array<{ type: string; detail: string; date: string }> = [];
  let currentDate = "";
  for (const raw of lines) {
    const line = raw.trim();
    if (!line) continue;
    const dateMatch = line.match(/^#\s+(\d{4}-\d{2}-\d{2})$/);
    if (dateMatch) {
      currentDate = dateMatch[1];
      continue;
    }
    const itemMatch = line.match(/^([\u4e00-\u9fa5A-Za-z]+)\s*-\s*(.+)$/);
    if (!itemMatch) continue;
    items.push({
      type: itemMatch[1].trim(),
      detail: itemMatch[2].trim(),
      date: currentDate,
    });
    if (items.length >= maxItems) break;
  }
  return items;
}

function getLogTagClass(type: string): string {
  if (type === "更新") return "update";
  if (type === "优化") return "optimize";
  if (type === "新增") return "add";
  if (type === "修复") return "fix";
  return "default";
}

function renderRecentLogs(config: any): string {
  const count = typeof config?.showLogNum === "number" ? config.showLogNum : 6;
  const logs = parseRecentLogs(logMd, Math.max(1, count));
  if (logs.length === 0) {
    return `
      <div class="index-sidebar-section">
        <h3 class="sidebar-title">最近更新 Recent Logs</h3>
        <div class="index-announcement"><p class="index-announcement-text">暂无更新内容</p></div>
      </div>
    `;
  }
  return `
    <div class="index-sidebar-section">
      <h3 class="sidebar-title">最近更新 Recent Logs</h3>
      <div class="index-log-list">
        ${logs
          .map(
            (log) => `<a class="index-log-item" href="/blog/log">
              <span class="index-log-tag ${getLogTagClass(log.type)}">${escapeHtml(log.type)}</span>
              <span class="index-log-detail">${escapeHtml(log.detail)}</span>
              <span class="index-log-date">${escapeHtml(log.date)}</span>
            </a>`
          )
          .join("")}
      </div>
      <div class="sidebar-more-wrap"><a href="/blog/log" class="sidebar-more-link">查看更多</a></div>
    </div>
  `;
}

function assembleSections(
  config: Record<string, boolean>,
  renderers: Record<string, () => string>,
  withDivider = false
): string {
  const displayed: string[] = [];
  for (const key of Object.keys(config)) {
    if (!config[key]) continue;
    const renderer = renderers[key];
    if (!renderer) continue;
    const html = renderer().trim();
    if (html) displayed.push(html);
  }
  if (!withDivider) return displayed.join("\n");
  return displayed
    .map((html, idx) => (idx < displayed.length - 1 ? `${html}\n<div class="index-divider"></div>` : html))
    .join("\n");
}

const mainSectionRenderers: Record<string, () => string> = {
  avatar_nickname: () => `
    <section class="home-block hero-section">
      <a class="hero-avatar-link" href="/posts/about">
        <img class="hero-avatar" src="/assets/img/touxiang.png" alt="头像" />
      </a>
      <h1 class="hero-title" id="Nickname">${escapeHtml(homeConfig.Nickname || "")}</h1>
    </section>
  `,
  contact_links: () => `
    <section class="home-block contact-section">
      ${renderContactLinks(homeConfig)}
    </section>
  `,
  social_links: () => `
    <section class="home-block social-section">
      <div class="social-icons" id="social-icons-container">${renderSocialLinks(homeConfig)}</div>
    </section>
  `,
  welcome_section: () => `
    <section class="home-block intro-section">
      <h2 class="welcome-title" id="welcome-title">${escapeHtml(homeConfig.welcomeTitle || "")}</h2>
      <p class="welcome-text" id="welcome-text">${escapeHtml(homeConfig.welcomeText || "")}</p>
    </section>
  `,
  typewriter: () => `
    <section class="home-block typewriter-section">
      <div class="typewriter-container">
        <div id="typewriter" class="typewriter"></div>
      </div>
    </section>
  `,
  recent_articles: () => `
    <section class="home-block content-section">
      <h2 class="recent-header"><a href="/posts">文章 Articles</a> <a href="/posts/rss.xml"><img class="rss-icon"
        src="/assets/img/rss.svg" alt="RSS"></a></h2>
      <div class="recent-posts">
        <div id="recent-posts"></div>
        <a href="/posts" class="more-link">更多</a>
      </div>
    </section>
  `,
  dynamic_feed: () => `
    <section class="home-block content-section dynamic-feed">
      <h2 class="recent-header"><a href="/blog/dt/">动态 Life Updates</a></h2>
      <div id="dynamic-entries"></div>
      <a href="/blog/dt" class="more-link">更多</a>
    </section>
  `,
};

const sidebarSectionRenderers: Record<string, () => string> = {
  datetime_display: () => `
    <div class="index-sidebar-section">
      <div class="time"> <span id="hours">00</span>:<span id="minutes">00</span>:<span id="seconds">00</span></div>
      <div class="date" id="date">2025年5月14日星期三</div>
    </div>
  `,
  ip_greeting: () => `
    <div class="index-sidebar-section">
      <div class="info" id="welcome-info"></div>
    </div>
  `,
  greeting_tip: () => `
    <div class="index-sidebar-section">
      <div class="greeting" id="greeting">祝你早安 午安 晚安</div>
      <div class="tip" id="tip">欢迎访问 Quark Blog ~</div>
    </div>
  `,
  online_preview: () => `
    <div class="index-sidebar-section">
      <h3 class="sidebar-title online-preview-title">在线 Online <span class="online-preview-count" id="online-preview-count">0</span></h3>
      <div id="online-preview">
        <div class="index-announcement"><p class="index-announcement-text">在线加载中...</p></div>
      </div>
      <div class="sidebar-more-wrap"><a href="/a/online" class="sidebar-more-link">查看在线</a></div>
    </div>
  `,
  github_promo: () => `
    <div class="index-sidebar-section">
      <div class="github-promo" id="github-promo-card">
        <div class="github-promo-loading">GitHub 数据加载中...</div>
      </div>
    </div>
  `,
  latest_updates: () => renderRecentLogs(homeConfig),
  announcement: () => `
    <div class="index-sidebar-section">
      <h3 class="sidebar-title">公告 Announcement</h3>
      <div class="index-announcement" id="announcement-container">${renderAnnouncement(homeConfig)}</div>
    </div>
  `,
  latest_video: () => `
    <div class="index-sidebar-section">
      <h3 class="sidebar-title">新视频 Latest Video</h3>
      <div id="latest-video-container" class="latest-video-container">
        <div class="loading-placeholder">视频加载中...</div>
      </div>
      <div class="sidebar-more-wrap"><a href="qtv" class="sidebar-more-link">查看更多</a></div>
    </div>
  `,
  comments: () => `
    <div class="index-sidebar-section">
      <h3 class="sidebar-title">留言 Comment</h3>
      <div id="recent-messages">
        <div class="index-announcement"><p class="index-announcement-text">留言加载中...</p></div>
      </div>
      <div class="sidebar-more-wrap"><a href="/blog/lyb" class="sidebar-more-link">查看更多 / 写留言</a></div>
    </div>
  `,
  friend_links: () => `
    <div class="index-sidebar-section">
      <h3 class="sidebar-title">友链 Friends</h3>
      <div id="friend-links">
        <div class="index-announcement"><p class="index-announcement-text">友链加载中...</p></div>
      </div>
      <div class="sidebar-more-wrap sidebar-more-wrap-sm"><a href="/blog/friends"
        class="sidebar-more-link">查看更多</a> / 添加友链请
        <a href="/blog/lyb" class="sidebar-more-link">在留言板留言</a>
      </div>
    </div>
  `,
};

const footerSectionRenderers: Record<string, () => string> = {
  visitor_stats: () => `
    <script async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
    <div class="footer-meta-item">
      访客 <span id="busuanzi_value_site_uv" class="footer-highlight"></span>
      · 来过 <span id="busuanzi_value_site_pv" class="footer-highlight"></span> 次
    </div>
  `,
  copyright_info: () => `
    <a class="footer-link footer-meta-item" href="/posts/copyright">
      © 2024 - ${currentYear} 蓝色奇夸克 | ${SITE_TITLE} All rights reserved.
    </a>
  `,
  icp_record: () => `
    <a class="footer-link footer-meta-item" href="https://icp.gov.moe/?keyword=20250234" target="_blank">
      <img src="assets/img/moe.png" alt="萌ICP备案图标" class="footer-record-icon">萌ICP备20250234号
    </a>
  `,
};

const mainContentHtml = assembleSections(indexConfig.main_content, mainSectionRenderers, false);
const sidebarContentHtml = assembleSections(indexConfig.sidebar, sidebarSectionRenderers, false);
const footerContentHtml = assembleSections(indexConfig.footer, footerSectionRenderers, false);

const postsTotal = Array.isArray(posts) ? posts.length : 0;
const dynamicTotal = parseDynamicEntries(dynamicMd).length;
const toolsTotal = Array.isArray(toolData?.categories)
  ? toolData.categories.reduce((sum: number, cat: any) => sum + (cat.tools?.length || 0), 0)
  : 0;
const gamesTotal = ["multiplayer", "singlePlayer", "classic"].reduce((sum, key) => {
  const list = Array.isArray(gameData?.[key]) ? gameData[key] : [];
  return sum + list.length;
}, 0);
const projectsTotal = Array.isArray(projectData?.categories)
  ? projectData.categories.reduce((sum: number, cat: any) => sum + (cat.projects?.length || 0), 0)
  : 0;

const showDynamicNum = typeof homeConfig.showDynamicNum === "number" ? homeConfig.showDynamicNum : 3;
const dynamicEntries = parseDynamicEntries(dynamicMd).slice(0, showDynamicNum).map((entry) => ({
  id: entry.id,
  title: entry.title,
  date: entry.date,
  content: entry.lines,
}));
const homePreloaded = {
  homeConfig,
  posts,
  friends,
  dynamicEntries,
  footerStats: {
    postsTotal,
    dynamicTotal,
    toolsTotal,
    projectsTotal,
    gamesTotal,
  },
};
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>首页 | 蓝色奇夸克のBlog - {SITE_TITLE}</title>
    <link rel="manifest" href="/json/manifest.json" />
    <meta name="description" content={`${SITE_TITLE} | 蓝色奇夸克的个人博客，分享技术、生活与思考。`} />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/css/index.css" />
    <link rel="stylesheet" href="/assets/css/dark-mode.css" />
    <link rel="stylesheet" href="/assets/css/dynamic-gallery.css" />
    <script is:inline define:vars={{ navConfig, homePreloaded, popups }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__HOME_PRELOADED__ = homePreloaded;
      window.__POPUPS_DATA__ = popups;
    </script>
    <script is:inline src="/assets/js/nav.js"></script>
    <script is:inline src="/assets/js/cursor-trail.js"></script>
    <script is:inline src="https://unpkg.com/marked@4.0.0/marked.min.js"></script>
    <script is:inline src="/assets/js/dynamic-gallery.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <meta name="referrer" content="never" />
  </head>

  <body>
    <link rel="stylesheet" href="/assets/css/shicha.css" />
    <div class="parallax-bg" id="parallaxBg"></div>
    <script is:inline src="/assets/js/shicha.js"></script>

    <div class="main-layout">
      <div class="main-content" set:html={mainContentHtml}></div>
      <div class="sidebar-index" set:html={sidebarContentHtml}></div>
    </div>
    <div class="footer-container">
      <div class="footer-card">
        <div class="footer-head">
          <div>
            <div class="footer-kicker">{footerTitleEn}</div>
            <div class="footer-title">
              <img class="footer-logo" src={footerLogo} alt="logo" />
              <span>{footerTitleCn}</span>
            </div>
          </div>
          <div class="footer-meta" set:html={footerContentHtml}></div>
        </div>
        <div class="footer-stats-grid" id="footer-static-stats">
          <a class="footer-stat footer-stat-link" href="/posts">
            <div class="footer-stat-label">文章总数</div>
            <div class="footer-stat-value" id="footer-post-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/blog/dt">
            <div class="footer-stat-label">动态总数</div>
            <div class="footer-stat-value" id="footer-dynamic-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/tool">
            <div class="footer-stat-label">工具 / 实验</div>
            <div class="footer-stat-value" id="footer-tool-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/games">
            <div class="footer-stat-label">游戏总数</div>
            <div class="footer-stat-value" id="footer-game-total">0</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/a/online">
            <div class="footer-stat-label">注册用户</div>
            <div class="footer-stat-value" id="footer-user-total">--</div>
          </a>
          <a class="footer-stat footer-stat-link" href="https://github.com/lsqkk" target="_blank" rel="noreferrer">
            <div class="footer-stat-label">开源项目</div>
            <div class="footer-stat-value" id="footer-project-total">--</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/blog/log">
            <div class="footer-stat-label">今日 Commit</div>
            <div class="footer-stat-value" id="footer-commit-total">--</div>
          </a>
          <a class="footer-stat footer-stat-link" href="/blog/log">
            <div class="footer-stat-label">安全运行</div>
            <div class="footer-stat-value" id="footer-running-days">--</div>
            <div class="footer-stat-meta">自 2025-01-31 起</div>
          </a>
        </div>
      </div>
    </div>
    <br /><br />

    <div id="popup-overlay" class="popup-overlay" style="display: none;">
      <div id="popup-container" class="popup-container">
        <div class="popup-header">
          <h3 id="popup-title"></h3>
          <button id="popup-close" class="popup-close-btn">&times;</button>
        </div>
        <div id="popup-content" class="popup-content"></div>
        <div class="popup-footer">
          <label class="popup-option">
            <input type="checkbox" id="popup-never-show" /> 不再显示
          </label>
          <button id="popup-confirm" class="popup-confirm-btn">知道了</button>
        </div>
      </div>
    </div>

    <div id="celebration-container"></div>

    <script is:inline src="/assets/js/qq-emotion-parser.min.js"></script>
    <script is:inline src="/assets/js/index.js"></script>
    <script is:inline src="/assets/js/popup.js"></script>

    <script is:inline src="__API_BASE__/api/firebase-config?v=1"></script>
    <script is:inline src="/assets/js/comment-shared.js"></script>
    <script is:inline src="/assets/js/comment-render-shared.js"></script>
    <script is:inline src="/assets/js/message.js"></script>
    <script is:inline src="/assets/js/dynamic-interactions.js"></script>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", function () {
          navigator.serviceWorker.register("/assets/js/sw.js").then(function (registration) {
            console.log("Service Worker 注册成功: ", registration);
          }).catch(function (error) {
            console.log("Service Worker 注册失败: ", error);
          });
        });
      }
    </script>

    <script is:inline src="/assets/js/disable-right-click.js"></script>
  </body>
</html>
