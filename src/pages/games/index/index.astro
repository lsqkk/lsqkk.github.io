---
import fs from "node:fs/promises";
import path from "node:path";

const PROJECT_ROOT = process.cwd();
const navConfigPath = path.join(PROJECT_ROOT, "json", "nav.json");
const gamesPath = path.join(PROJECT_ROOT, "assets", "pages", "games", "game.json");

const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const gamesData = JSON.parse(await fs.readFile(gamesPath, "utf8"));
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>夸克游戏 - 夸克博客</title>
    <meta name="description" content="夸克博客趣味网页游戏集合，分为对战游戏、个人游戏和经典游戏复刻。" />
    <link rel="icon" href="/assets/img/logo_blue.png" type="image/png" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="stylesheet" href="/assets/pages/games/style.css" />
    <script is:inline define:vars={{ navConfig, gamesData }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__GAMES_DATA__ = gamesData;
    </script>
    <script is:inline src="/assets/js/cursor-trail.js"></script>
  </head>

  <body>
    <link rel="stylesheet" href="/assets/css/shicha.css" />
    <div class="parallax-bg" id="parallaxBg"></div>
    <script is:inline src="/assets/js/shicha.js"></script>

    <script is:inline src="/assets/js/nav.js"></script>

    <div class="game-container" id="game-container">
      <h1 class="page-title">游戏 / GAMES</h1>
    </div>

    <script is:inline src="/assets/pages/games/game.js"></script>
    <script is:inline src="/assets/js/disable-right-click.js"></script>
  </body>
</html>
