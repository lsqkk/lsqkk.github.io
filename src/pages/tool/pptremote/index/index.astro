---
import LuxuryBackground from "../../../../components/LuxuryBackground.astro";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---

<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>夸克PPT遥控 | 手机遥控电脑PPT - {SITE_TITLE}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png">
    <meta name="keywords" content={`PPT, 遥控, 手机, 前端, firebase, 电脑, 放映, ${SITE_TITLE}`}>
    <meta name="description" content="夸克PPT遥控，基于Firebase RTDB的免费、快捷、超轻量级的电脑PPT遥控工具。">
    <script is:inline src="/assets/js/nav.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/8.10.0/firebase-app.js"></script>
    <script is:inline src="https://www.gstatic.com/firebasejs/8.10.0/firebase-database.js"></script>
    <link rel="stylesheet" href="/assets/pages/tool/pptremote/style.css">
    <link rel="stylesheet" href="/assets/css/basic.css">


</head>

<body class="luxury-body">
    <LuxuryBackground />
    <div class="main-content-wrapper-remote">
        <h1 class="page-title">PPT 无线遥控</h1>

        <div class="container-remote">

            <div class="card-remote" id="join-section-remote">
                <h2>手机也可以是 PPT 遥控器</h2>
                <button id="start-projector-btn" class="remote-button-primary">我是电脑/放映端</button>


                <button id="join-controller-btn" class="remote-button-primary remote-button-secondary">我是手机/遥控器</button>
                <input type="text" id="room-code-input-remote" class="remote-input" placeholder="遥控器端于此键入连接码后 再点击上方按钮"
                    maxlength="3">
            </div>

            <div class="card-remote" id="projector-view" style="display: none;">
                <h2>放映端：等待本地桥接</h2>
                <div id="projector-status-box">
                    <p>🚨 重要：请先在电脑上<br><strong style="color:var(--main-red);font-size:1.1em;">右键以管理员身份运行</strong><br><a href="/assets/exe/quark-ppt-bridge-lite.exe">Quark PPT 桥接组件</a> (点击下载)<br>运行后再刷新此页</p>
                    <p>请在遥控端输入当前连接码：<br><span id="projector-code-display"
                            style="font-size: 1.5em; color: var(--main-red); font-weight: bold;">---</span></p>
                    <p>本地连接状态：<span id="local-bridge-status" class="alert-error">断开中 (ws://localhost:8080)</span></p>
                    <p>Firebase 监听状态：<span id="firebase-listen-status">未启动</span></p>
                </div>
                <p style="margin-top: 15px;">连接成功后请切换到 PowerPoint 演示模式</p>
            </div>

            <div class="card-remote" id="controller-view" style="display: none;">
                <h2>遥控端：控制面板</h2>
                <p>当前房间：<span id="controller-code-display"
                        style="font-size: 1.2em; color: var(--main-blue); font-weight: bold;">---</span></p>
                <p id="command-status" style="margin: 0 0 15px 0; color: #666; font-weight: 500;">状态: 已连接</p>

                <div class="control-section">
                    <div class="control-section-header">导航</div>
                    <div class="control-grid">
                        <button class="control-btn nav-prev" onclick="sendCommand('prev')">◀ 上一页</button>
                        <button class="control-btn nav-next" onclick="sendCommand('next')">下一页 ▶</button>
                        <button class="control-btn nav-edge" onclick="sendCommand('first')">⏮ 首页</button>
                        <button class="control-btn nav-edge" onclick="sendCommand('last')">尾页 ⏭</button>
                    </div>
                </div>

                <div class="control-section">
                    <div class="control-section-header">屏幕</div>
                    <div class="control-grid three-col">
                        <button class="control-btn screen-black" onclick="sendCommand('blank')">⬛ 黑屏</button>
                        <button class="control-btn screen-white" onclick="sendCommand('white')">⬜ 白屏</button>
                        <button class="control-btn screen-end" onclick="sendCommand('endshow')">⏹ 退出</button>
                    </div>
                </div>

                <div class="control-section">
                    <div class="control-section-header">指针模式</div>
                    <div class="control-grid three-col">
                        <button class="control-btn ptr-laser" onclick="sendCommand('pointer')">🖱 激光笔</button>
                        <button class="control-btn ptr-pen" onclick="sendCommand('pen')">🖊 笔模式</button>
                        <button class="control-btn ptr-arrow" onclick="sendCommand('arrow')">➤ 箭头</button>
                        <button class="control-btn ptr-eraser" onclick="sendCommand('eraser')">🧹 橡皮擦</button>
                        <button class="control-btn ptr-hide" onclick="sendCommand('hideptr')">🙈 隐藏</button>
                        <button class="control-btn ptr-show" onclick="sendCommand('showptr')">👁 显示</button>
                    </div>
                </div>

                <div class="control-section">
                    <div class="control-section-header">缩放</div>
                    <div class="control-grid three-col" style="grid-template-columns: 1fr 1fr 1fr; max-width: 70%; margin: 0 auto;">
                        <button class="control-btn zoom-in" onclick="sendCommand('zoomin')">🔍+ 放大</button>
                        <button class="control-btn zoom-out" onclick="sendCommand('zoomout')">🔍− 缩小</button>
                    </div>
                </div>
            </div>

            <div class="card-remote">
                <h2>实时日志</h2>
                <div id="status-remote">应用状态：未启动</div>
            </div>

        </div>
    </div>

    <script is:inline src="__API_BASE__/api/firebase-config?v=1"></script>
    <script is:inline src="/assets/pages/tool/pptremote/app.js"></script>
</body>

</html>







