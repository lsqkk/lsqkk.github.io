---
import ShichaBackground from "../../../../components/ShichaBackground.astro";
import fs from "node:fs/promises";
import path from "node:path";

const PROJECT_ROOT = process.cwd();
const navConfigPath = path.join(PROJECT_ROOT, "src", "config", "json", "nav.json");
const friendsPath = path.join(PROJECT_ROOT, "src", "config", "json", "friends.json");

const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const friendsData = JSON.parse(await fs.readFile(friendsPath, "utf8"));
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`${SITE_TITLE}的友链页面，展示朋友们和博主的信息。`} />
    <title>友链 Friends - {SITE_TITLE}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/pages/blog/friends/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script is:inline define:vars={{ navConfig, friendsData }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__FRIENDS_DATA__ = friendsData;
    </script>
    <script is:inline src="/assets/js/cursor-trail.js"></script>
    <script is:inline src="/assets/js/nav.js"></script>
    <script is:inline defer src="/assets/pages/blog/friends/app.js"></script>
  </head>

  <body>
    <ShichaBackground />
    <div class="page-content">
      <h1 class="page-title">友链 / FRIENDS</h1>
      <section class="friends-section">
        <h2 class="section-title">
          <i class="fas fa-user-friends"></i>
          朋友们 / FRIENDS
        </h2>
        <div class="friends-container" id="friendsContainer">
          <div class="loading">正在加载友链列表...</div>
        </div>
      </section>

      <section class="info-section">
        <h2 class="section-title">
          <i class="fas fa-user-circle"></i>
          我的信息 / MY INFO
          <span class="copy-hint">（点击对应项即可复制）</span>
        </h2>
        <div class="glass-card">
          <div class="my-info-grid">
            <div class="my-info-item" data-copy={`${SITE_TITLE} / Quark Blog`}>
              <div class="info-label">网站名称</div>
              <div class="info-value">{SITE_TITLE} / Quark Blog</div>
              <div class="copy-icon"><i class="fas fa-copy"></i></div>
            </div>
            <div class="my-info-item" data-copy="lsqkk.github.io">
              <div class="info-label">网站地址</div>
              <div class="info-value">lsqkk.github.io</div>
              <div class="copy-icon"><i class="fas fa-copy"></i></div>
            </div>
            <div class="my-info-item" data-copy={`lsqkk.github.io${SITE_LOGO_URL}`}>
              <div class="info-label">网站图标</div>
              <div class="info-value">lsqkk.github.io{SITE_LOGO_URL}</div>
              <div class="copy-icon"><i class="fas fa-copy"></i></div>
            </div>
            <div class="my-info-item" data-copy="蓝色奇夸克 / Quark">
              <div class="info-label">站主名称</div>
              <div class="info-value">蓝色奇夸克 / Quark</div>
              <div class="copy-icon"><i class="fas fa-copy"></i></div>
            </div>
            <div class="my-info-item" data-copy="lsqkk.github.io/assets/img/touxiang.png">
              <div class="info-label">站主头像</div>
              <div class="info-value">lsqkk.github.io/assets/img/touxiang.png</div>
              <div class="copy-icon"><i class="fas fa-copy"></i></div>
            </div>
          </div>
          <div class="my-info-note">
            <i class="fas fa-link"></i> 若想与我交换友链，请前往 <a href="/blog/lyb" class="notice-link">留言板</a>
            留言告知，我会尽快添加！
          </div>
        </div>
      </section>

      <footer class="page-footer">
        <p>© 2024 - <span id="currentYear">2026</span> 友链 / {SITE_TITLE} All rights reserved.</p>
      </footer>
    </div>

    <div id="copyToast" class="copy-toast">
      <i class="fas fa-check-circle"></i> <span id="copyToastText">已复制到剪贴板</span>
    </div>
    <script is:inline src="/assets/js/disable-right-click.js"></script>
  </body>
</html>







