---
import fs from "node:fs/promises";
import path from "node:path";

const PROJECT_ROOT = process.cwd();
const navConfigPath = path.join(PROJECT_ROOT, "json", "nav.json");
const functionsPath = path.join(PROJECT_ROOT, "assets", "pages", "blog", "functions.json");

const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const blogFunctions = JSON.parse(await fs.readFile(functionsPath, "utf8"));
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>功能导航 - {SITE_TITLE}</title>
    <meta name="description" content="夸克博客网站功能导航页面，提供功能指引" />
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <link rel="stylesheet" href="/assets/pages/blog/blog.css" />
    <script is:inline define:vars={{ navConfig, blogFunctions }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__BLOG_FUNCTIONS__ = blogFunctions;
    </script>
    <script is:inline src="/assets/js/nav.js"></script>
  </head>

  <body>
    <link rel="stylesheet" href="/assets/css/shicha.css" />
    <div class="parallax-bg" id="parallaxBg"></div>
    <script is:inline src="/assets/js/shicha.js"></script>
    <div class="container">
      <h1 class="page-title">功能导航</h1>
      <div id="functions-container"></div>
    </div>
    <script is:inline src="/assets/pages/blog/blog.js"></script>
  </body>
</html>
