---
import ShichaBackground from "../../../../components/ShichaBackground.astro";
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
import CommentIdentityFields from "../../../../components/CommentIdentityFields.astro";
---

<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <link rel="stylesheet" href="/assets/css/basic.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>留言板 - {SITE_TITLE}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/assets/pages/blog/lyb/lyb.css">
    <link rel="icon" href={SITE_LOGO_URL} type="image/png">
    <link rel="stylesheet" href="/assets/css/cursor.css">
    <script is:inline src="/assets/js/cursor-trail.js"></script>
    <script is:inline src="https://unpkg.com/marked@4.0.0/marked.min.js"></script>
    <script is:inline src="/assets/js/nav.js"></script>
</head>

<body class="light-mode">

    <ShichaBackground />
    <div class="container">

        <!-- Header -->
        <header>
            <h1 class="page-title">留言板 / Message</h1>
            <div class="header-toolbar">
                <a href="/" class="nav-link"><i class="fas fa-home"></i> 主页</a>
                <a href="/a/chat-room/" class="nav-link"><i class="fas fa-comments"></i> 聊天室</a>
                <a href="/blog/tieba/" class="nav-link"><i class="fas fa-comments"></i> 贴吧</a>
                <button class="admin-toggle" id="adminToggle" onclick="toggleAdminPanel()" title="管理">
                    <i class="fas fa-cog"></i>
                </button>
            </div>
        </header>

        <!-- Admin inline (hidden by default) -->
        <div class="admin-inline" id="adminPanel" style="display: none;">
            <div class="admin-inner" id="adminLoginForm">
                <span class="admin-label">管理员</span>
                <input type="password" id="adminPassword" placeholder="输入密码">
                <button class="admin-btn" onclick="adminLogin()">登录</button>
            </div>
            <div class="admin-inner" id="adminActions" style="display: none;">
                <span class="admin-label"><i class="fas fa-shield-alt"></i> 管理员模式</span>
                <button class="admin-btn" onclick="logoutAdmin()">退出</button>
            </div>
        </div>

        <!-- Main glass panel: form + messages -->
        <div class="main-section">

            <!-- Compose area -->
            <div class="compose-area">
                <div class="compose-identity">
                    <CommentIdentityFields variant="lyb" />
                </div>
                <textarea id="messageContent" rows="3" placeholder="写下您的留言..." class="compose-input"></textarea>
                <div class="compose-footer">
                    <label class="markdown-toggle">
                        <input type="checkbox" id="useMarkdown" checked>
                        <span>Markdown</span>
                    </label>
                    <button class="submit-btn" onclick="submitMessage()"><i class="fas fa-paper-plane"></i> 发布留言</button>
                </div>
            </div>

            <!-- Messages area -->
            <div class="messages-area">
                <div class="messages-header">
                    <span class="messages-title">全部留言 <span class="messages-count" id="messageCount">0</span></span>
                    <div class="messages-controls">
                        <div class="sort-group" id="sortGroup">
                            <button class="sort-btn active" data-sort="newest" onclick="setSort('newest')">最新</button>
                            <button class="sort-btn" data-sort="oldest" onclick="setSort('oldest')">最早</button>
                            <button class="sort-btn" data-sort="hot" onclick="setSort('hot')">最热</button>
                        </div>
                        <div class="search-wrapper">
                            <i class="fas fa-search search-icon-inline"></i>
                            <input type="text" id="searchInput" placeholder="搜索留言..." class="search-input-inline">
                        </div>
                    </div>
                </div>

                <div class="messages-list" id="messagesContainer">
                    <!-- 留言将通过JavaScript动态加载 -->
                </div>

                <div class="pagination" id="pagination">
                    <!-- 分页按钮将通过JavaScript动态生成 -->
                </div>
            </div>

        </div>
    </div>

    <script is:inline src="__API_BASE__/api/firebase-config?v=1"></script>
    <script is:inline src="/assets/js/firebase-ready.js"></script>
    <script is:inline src="/assets/js/comment-shared.js"></script>
    <script is:inline src="/assets/js/comment-input-shared.js"></script>
    <script is:inline src="/assets/js/comment-list-shared.js"></script>
    <script is:inline src="/assets/js/comment-render-shared.js"></script>
    <script is:inline src="/assets/pages/blog/lyb/lyb.js"></script>
    <script is:inline src="/assets/js/disable-right-click.js"></script>
</body>

</html>
