---
import ShichaBackground from "../../../../components/ShichaBackground.astro";
import fs from "node:fs/promises";
import path from "node:path";

const PROJECT_ROOT = process.cwd();
const navConfigPath = path.join(PROJECT_ROOT, "json", "nav.json");
const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>项目 - {SITE_TITLE}</title>
    <meta name="description" content={`${SITE_TITLE} 项目页面，展示 GitHub 项目仓库`} />
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <link rel="stylesheet" href="/assets/pages/blog/project/project.css" />
    <script is:inline define:vars={{ navConfig }}>
      window.__NAV_CONFIG__ = navConfig;
    </script>
    <script is:inline src="/assets/js/nav.js"></script>
  </head>
  <body>
    <ShichaBackground />

    <main class="project-container">
      <header class="project-head">
        <h1>项目 / Projects</h1>
        <p>展示公开仓库，按最近更新时间排序</p>
      </header>
      <section id="project-grid" class="project-grid">
        <div class="project-loading">项目数据加载中...</div>
      </section>
    </main>

    <script is:inline src="/assets/pages/blog/project/project.js"></script>
  </body>
</html>








