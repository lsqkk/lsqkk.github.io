---
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <title>登录回调 - {SITE_TITLE}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <script is:inline>
      const urlParams = new URLSearchParams(window.location.search);
      const code = urlParams.get("code");
      async function fetchGithubUser(authCode) {
        try {
          const resp = await fetch(`__API_BASE__/api/github-user?code=${encodeURIComponent(authCode)}`, { cache: "no-store" });
          if (!resp.ok) return null;
          const data = await resp.json();
          return data && typeof data === "object" ? data : null;
        } catch {
          return null;
        }
      }
      if (code) {
        localStorage.setItem("github_code", code);
        fetchGithubUser(code).then((user) => {
          if (user) {
            localStorage.setItem("github_user", JSON.stringify(user));
          }
        }).finally(() => {
          window.location.href = "/";
        });
      }
    </script>
  </head>
  <body>
    <p>登录中...</p>
    <script is:inline src="/assets/js/disable-right-click.js"></script>
  </body>
</html>
