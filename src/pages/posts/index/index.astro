---
import fs from "node:fs/promises";
import path from "node:path";

const PROJECT_ROOT = process.cwd();
const navConfigPath = path.join(PROJECT_ROOT, "json", "nav.json");
const postsPath = path.join(PROJECT_ROOT, "posts", "posts.json");

const navConfig = JSON.parse(await fs.readFile(navConfigPath, "utf8"));
const postsData = JSON.parse(await fs.readFile(postsPath, "utf8"));
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
const currentYear = new Date().getFullYear();
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>文章 / POSTS - {SITE_TITLE}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/css/posts.css" />
    <script is:inline define:vars={{ navConfig, postsData }}>
      window.__NAV_CONFIG__ = navConfig;
      window.__POSTS_DATA__ = postsData;
    </script>
    <script is:inline src="/assets/js/cursor-trail.js"></script>
  </head>

  <body>
    <link rel="stylesheet" href="/assets/css/shicha.css" />
    <div class="parallax-bg" id="parallaxBg"></div>
    <script is:inline src="/assets/js/shicha.js"></script>

    <script is:inline src="/assets/js/nav.js"></script>

    <div class="posts-container">
      <h1 class="page-title">文章 / POSTS</h1>
      <h2 class="page-subtitle">
        RSS订阅链接: <a href="https://lsqkk.github.io/posts/rss.xml" target="_blank">https://lsqkk.github.io/posts/rss.xml</a>
      </h2>
      <div id="searchResults" class="search-results"></div>
      <div id="tagFilter" class="tag-filter"></div>
      <div id="posts"></div>
      <div class="pagination" id="pagination">
        <button class="page-btn prev-btn" onclick="prevPage()">上一页</button>
        <div class="page-numbers" id="pageNumbers"></div>
        <button class="page-btn next-btn" onclick="nextPage()">下一页</button>
      </div>
    </div>

    <div class="copyright">© 2024 - {currentYear} 蓝色奇夸克 / {SITE_TITLE} All rights reserved</div>
    <script is:inline src="/assets/js/posts.js"></script>
    <script is:inline src="/assets/js/disable-right-click.js"></script>
  </body>
</html>
