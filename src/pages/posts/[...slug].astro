---
import { getCollection, render, type CollectionEntry } from "astro:content";
import fs from "node:fs/promises";
import path from "node:path";
import PostLayout from "../../layouts/PostLayout.astro";
import { buildPostCaseMap, resolveCaseSlug } from "../../utils/post-case-map";

type PostEntry = CollectionEntry<"posts">;


function normalizeDate(date: unknown): string {
  if (!date) return "1970-01-01";
  if (date instanceof Date) return date.toISOString().slice(0, 10);
  const str = String(date).trim();
  const hit = str.match(/^(\d{4})[-/年](\d{1,2})[-/月](\d{1,2})/);
  if (hit) return `${hit[1]}-${hit[2].padStart(2, "0")}-${hit[3].padStart(2, "0")}`;
  return str;
}

function normalizeTags(tags: unknown): string[] {
  if (!tags) return [];
  if (Array.isArray(tags)) return tags.map((tag) => String(tag).trim()).filter(Boolean);
  return String(tags)
    .split(",")
    .map((tag) => tag.trim())
    .filter(Boolean);
}

function normalizeColumns(columns: unknown): string[] {
  if (!columns) return [];
  const raw = Array.isArray(columns) ? columns : String(columns).split(",");
  return raw
    .map((item) => String(item).trim().replace(/^["']|["']$/g, ""))
    .map((item) => item.replace(/[\\/]/g, "").trim())
    .filter(Boolean);
}

function extractTitle(entry: PostEntry): string {
  const match = entry.body.match(/^#\s+(.+)$/m);
  if (match) return match[1].trim();
  const slugPart = entry.id.replace(/\.md$/i, "").split("/").pop() || "untitled";
  return slugPart;
}

function getWordCount(entry: PostEntry): number {
  return entry.body.trim().length;
}

export async function getStaticPaths() {
  const [posts, caseMap] = await Promise.all([getCollection("posts"), buildPostCaseMap()]);
  return posts.map((post) => ({
    params: { slug: resolveCaseSlug(post.id.replace(/\.md$/i, ""), caseMap) },
    props: { post },
  }));
}

const { post } = Astro.props as { post: PostEntry };
const PROJECT_ROOT = process.cwd();
const postsIndexPath = path.join(PROJECT_ROOT, "posts", "posts.json");
const coverMap = new Map<string, string>();
try {
  const postsIndex = JSON.parse(await fs.readFile(postsIndexPath, "utf8"));
  if (Array.isArray(postsIndex)) {
    postsIndex.forEach((item) => {
      if (item && item.file && typeof item.cover === "string" && item.cover.trim()) {
        coverMap.set(String(item.file), item.cover.trim());
      }
    });
  }
} catch (err) {
  console.warn("读取 posts.json 失败:", err);
}
const title = extractTitle(post);
const date = normalizeDate(post.data.date);
const tags = normalizeTags(post.data.tags);
const columns = normalizeColumns((post.data as any).columns ?? (post.data as any).column ?? (post.data as any)["专栏"]);
const wordCount = getWordCount(post);
const mdFile = post.id.split("/").pop() || post.id;
const coverUrl = coverMap.get(post.id) || "";
const caseMap = await buildPostCaseMap();
const currentPostPath = resolveCaseSlug(post.id.replace(/\.md$/i, ""), caseMap);

const allPosts = await getCollection("posts");
const sortedPosts = [...allPosts].sort((a, b) => {
  const dateCmp = normalizeDate(b.data.date).localeCompare(normalizeDate(a.data.date));
  if (dateCmp !== 0) return dateCmp;
  return b.id.localeCompare(a.id);
});

const currentIndex = sortedPosts.findIndex((item) => item.id === post.id);
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const prevPost = currentIndex >= 0 && currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;

const { Content } = await render(post);
const pageTitle = `${title} - ${SITE_TITLE}`;
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
---
<PostLayout
  pageTitle={pageTitle}
  postTitle={title}
  date={date}
  tags={tags}
  columns={columns}
  wordCount={wordCount}
  mdFile={mdFile}
  coverUrl={coverUrl}
  currentPostPath={currentPostPath}
  prevPostTitle={prevPost ? extractTitle(prevPost) : ""}
  prevPostUrl={prevPost ? `/posts/${resolveCaseSlug(prevPost.id.replace(/\.md$/i, ""), caseMap)}` : ""}
  nextPostTitle={nextPost ? extractTitle(nextPost) : ""}
  nextPostUrl={nextPost ? `/posts/${resolveCaseSlug(nextPost.id.replace(/\.md$/i, ""), caseMap)}` : ""}
>
  <Content />
</PostLayout>
