---
interface Props {
  pageTitle: string;
  postTitle: string;
  postDescription: string;
  date: string;
  tags: string[];
  columns: string[];
  wordCount: number;
  mdFile: string;
  coverUrl: string;
  currentPostPath: string;
  prevPostTitle: string;
  prevPostUrl: string;
  nextPostTitle: string;
  nextPostUrl: string;
}

const {
  pageTitle,
  postTitle,
  postDescription,
  date,
  tags,
  columns,
  wordCount,
  mdFile,
  coverUrl,
  currentPostPath,
  prevPostTitle,
  prevPostUrl,
  nextPostTitle,
  nextPostUrl,
} =
  Astro.props;
const readTime = Math.ceil(wordCount / 400);
import { SITE_TITLE, SITE_LOGO_URL } from "@siteConfig";
import GlowFollow from "../components/GlowFollow.astro";
const currentYear = new Date().getFullYear();

function buildColumnHref(columnName: string): string {
  return `/posts/${encodeURIComponent(columnName)}`;
}
function buildTagHref(tagName: string): string {
  return `/posts?tag=${encodeURIComponent(tagName)}`;
}
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <title>{pageTitle}</title>
    <link rel="icon" href={SITE_LOGO_URL} type="image/png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={postDescription} />
    <meta property="og:title" content={postTitle} />
    <meta property="og:description" content={postDescription} />
    <meta property="og:type" content="article" />
    <meta property="og:image" content={SITE_LOGO_URL} />
    <meta property="og:url" content={"https://lsqkk.github.io" + currentPostPath} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={postTitle} />
    <meta name="twitter:description" content={postDescription} />
    <link rel="alternate" type="application/rss+xml" title="夸克博客 RSS" href="/posts/rss.xml" />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": {postTitle ? JSON.stringify(postTitle) : "未命名文章"},
        "description": {postDescription ? JSON.stringify(postDescription) : "无描述"},
        "datePublished": {date ? JSON.stringify(date) : "null"},
        "wordCount": {wordCount || 0},
        "author": {
          "@type": "Person",
          "name": "蓝色奇夸克",
          "url": "https://github.com/lsqkk"
        },
        "publisher": {
          "@type": "Person",
          "name": "蓝色奇夸克"
        },
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": {("https://lsqkk.github.io" + currentPostPath) ? JSON.stringify("https://lsqkk.github.io" + currentPostPath) : "null"}
        },
        "keywords": {tags && tags.length > 0 ? JSON.stringify(tags.join(", ")) : "null"}
      }
    </script>
    <link rel="stylesheet" href="/assets/css/cursor.css" />
    <link rel="stylesheet" href="/assets/css/basic.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="stylesheet" href="/assets/css/post.css" />
    <link id="dynamic-gallery-style" rel="stylesheet" href="/assets/css/dynamic-gallery.css" />
    <link id="post-annotation-style" rel="stylesheet" href="/assets/css/post-annotation.css" />
    <link rel="stylesheet" href="/assets/css/code.css" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" media="print" onload="this.media='all'" />
    <script is:inline src="/assets/js/nav.js"></script>
    <script is:inline src="/assets/js/copyright-injector.js"></script>
    <script is:inline async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js" defer></script>
    <link rel="stylesheet" href="https://cdn.bootcdn.net/ajax/libs/KaTeX/0.16.9/katex.min.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/styles/github-dark.min.css"
    />
  </head>

  <body
    style="background: url('/assets/img/bg.png') no-repeat center center; background-size: cover; position: relative; background-attachment: fixed;"
  >
    <link rel="stylesheet" href="/assets/css/shicha.css" />
    <div class="parallax-bg" id="parallaxBg"></div>
    <script is:inline src="/assets/js/shicha.js"></script>
    <GlowFollow />
    <script is:inline src="/assets/js/cursor-trail.js" defer></script>
    <script id="dynamic-gallery-script" is:inline src="/assets/js/dynamic-gallery.js"></script>
    <div class="sidebar-backdrop" onclick="toggleSidebar()"></div>
    <div class="sidebar">
      <div class="sidebar-content" id="sidebarContent">
        <div id="toc-loading" style="display: none;">目录加载中...</div>
        <div class="sidebar-main-content"></div>
        <div class="sidebar-footer">
          <a href="/index.html" style="text-decoration: none;">博客主页</a>
          <a href="/posts" style="text-decoration: none;">文章</a>
          <a href="/games" style="text-decoration: none;">夸克游戏</a>
          <a href="/a/qai" style="text-decoration: none;">Q-AI WebUI</a>
          <a href="/tool" style="text-decoration: none;">更多工具</a>
        </div>
      </div>
    </div>

    <div class="morenpost">
      <div class="post-header">
        {coverUrl ? (
          <div class="post-hero">
            <img
              src={coverUrl}
              alt={postTitle}
              class="post-hero-image"
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer"
            />
            <div class="post-hero-overlay">
              <div class="post-hero-copy">
                <div class="post-header-actions post-header-actions-hero">
                  <button
                    class="post-description-trigger"
                    type="button"
                    aria-label="查看文章简介"
                    data-tooltip={postDescription}
                  >
                    <span class="post-description-trigger-icon">i</span>
                  </button>
                </div>
                <h1 class="post-hero-title">{postTitle}</h1>
              </div>
            </div>
          </div>
        ) : (
          <>
            <h1 class="post-title-main">{postTitle}</h1>
            <div class="post-header-actions post-header-actions-plain">
              <button
                class="post-description-trigger"
                type="button"
                aria-label="查看文章简介"
                data-tooltip={postDescription}
              >
                <span class="post-description-trigger-icon">i</span>
              </button>
            </div>
          </>
        )}
      </div>
      <div class="post-meta">
        <div class="post-meta-left">
          <div id="post-date" class="post-meta-item">发表于 {date}</div>
        </div>
        <div class="post-meta-right">
          <div class="post-meta-item">
            <i class="fa-regular fa-eye post-meta-view-icon"></i>
            <span id="busuanzi_value_page_pv"></span>
          </div>
          <div class="post-meta-item" id="post-wordcount">{wordCount}字 · {readTime}min</div>
        </div>
      </div>

      {columns.length > 0 && (
        <div class="post-column-note">
          被
          {columns.map((column, index) => (
            <>
              <a href={buildColumnHref(column)} class="post-column-link">{column}</a>
              {index < columns.length - 1 ? "、" : ""}
            </>
          ))}
          专栏收录
        </div>
      )}

      <div
        id="post-tags-container"
        class="post-tags"
        data-md-file={mdFile}
        data-post-path={currentPostPath}
        data-date={date}
        data-word-count={String(wordCount)}
        data-tags={JSON.stringify(tags)}
        data-description={postDescription}
        data-prev-title={prevPostTitle}
        data-prev-url={prevPostUrl}
        data-next-title={nextPostTitle}
        data-next-url={nextPostUrl}
      >
        {tags.map((tag) => (
          <a class="post-tag post-tag-link" href={buildTagHref(tag)}>{tag}</a>
        ))}
      </div>

      <div id="content" class="post-content">
        <slot />
      </div>

      <hr />

      <div>
        <center>
          <div style="margin: 20px;">
            <button class="share-button" onclick="copyLink()">复制本文链接</button>
          </div>
          <div class="donate-section">
            <p class="donate-text">如果这篇文章对你有帮助，欢迎赞赏支持。</p>
            <img src="/assets/img/buymeacoffee.png" alt="赞赏码" class="donate-qr" loading="lazy" />
          </div>
          <div class="native-share">
            <button class="share-button" onclick="window.open('https://service.weibo.com/share/share.php?title='+encodeURIComponent(document.title)+'&url='+encodeURIComponent(location.href),'_blank','width=600,height=500')">分享到微博</button>
            <button class="share-button" onclick="window.open('https://connect.qq.com/widget/shareqq/index.html?title='+encodeURIComponent(document.title)+'&url='+encodeURIComponent(location.href),'_blank','width=600,height=500')">分享到QQ</button>
          </div>
        </center>
      </div>
    </div>

    <script is:inline defer src="https://cdn.bootcdn.net/ajax/libs/KaTeX/0.16.9/katex.min.js"></script>
    <script is:inline defer src="https://cdn.bootcdn.net/ajax/libs/KaTeX/0.16.9/contrib/auto-render.min.js"></script>
    <script is:inline src="/assets/js/comment-shared.js"></script>
    <script is:inline src="/assets/js/comment-render-shared.js"></script>
    <script is:inline src="/assets/js/firebase-ready.js"></script>
    <script is:inline id="post-annotation-script" defer src="/assets/js/post-annotation.js"></script>
    <script is:inline src="/assets/js/post-standalone.js"></script>
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        const content = document.getElementById("content");
        const footnotes = content?.querySelector(".footnotes[data-footnotes]");
        if (!footnotes) return;

        footnotes.id = "post-footnotes";
        footnotes.classList.add("post-footnotes");
        footnotes.setAttribute("aria-label", "参考文献");

        const title = footnotes.querySelector("#footnote-label");
        if (title) {
          title.textContent = "参考文献";
          title.className = "post-footnotes-title";
        }

        footnotes.querySelector("ol")?.classList.add("post-footnotes-list");
        footnotes.querySelectorAll("li").forEach((item) => item.classList.add("post-footnote-item"));

        content.querySelectorAll("a[data-footnote-ref]").forEach((link) => {
          link.classList.add("post-footnote-ref");
          link.closest("sup")?.classList.add("post-footnote-ref-wrap");
        });
        footnotes.querySelectorAll("a[data-footnote-backref]").forEach((link) => {
          link.classList.add("post-footnote-backref");
        });
      });
    </script>

    <div class="morenpost">
      <div class="giscus"></div>
    </div>

    <div style="text-align: center; padding: 50px;">
      <a
        href="/posts/copyright"
        style="text-decoration: none; color: rgb(255, 255, 255); text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);"
      >
        © 2024 - {currentYear} {SITE_TITLE} All rights reserved.
      </a>
    </div>

    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/highlight.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/languages/python.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/languages/javascript.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/languages/typescript.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/languages/cpp.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/languages/bash.min.js"></script>
    <script is:inline defer src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.8.0/languages/nginx.min.js"></script>
    <script is:inline src="/assets/js/code.js"></script>
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo="lsqkk/lsqkk.github.io"
      data-repo-id="R_kgDONya5nQ"
      data-category="Announcements"
      data-category-id="DIC_kwDONya5nc4CnVr4"
      data-mapping="url"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="preferred_color_scheme"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async
    >
    </script>

    <div class="post-fab-stack">
      <button class="fab-btn sidebar-toggle" type="button" onclick="toggleSidebar()" aria-label="打开目录" aria-expanded="false">☰</button>
      <button class="fab-btn back-to-top" type="button" aria-label="回到顶部">
        <span class="back-to-top-icon">↑</span>
        <span class="back-to-top-text">回到顶部</span>
      </button>
    </div>
  </body>
</html>
