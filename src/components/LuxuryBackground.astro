---
const { className = "" } = Astro.props;
---
<style is:global>
  body.luxury-body {
    background-color: #f5f8fc;
    background-image:
      radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.9), transparent 48%),
      radial-gradient(circle at 86% 22%, rgba(240, 247, 255, 0.85), transparent 52%),
      linear-gradient(170deg, rgba(250, 252, 255, 0.92), rgba(232, 239, 248, 0.88)),
      url('/assets/img/bg.png');
    background-repeat: no-repeat;
    background-position: center center;
    background-attachment: fixed;
    background-size: cover;
  }

  body.dark-mode.luxury-body {
    background: linear-gradient(160deg, rgba(5, 10, 22, 0.88), rgba(2, 6, 23, 0.92)),
      url('/assets/img/bg.png') no-repeat center center fixed;
    background-size: cover;
  }

  .luxury-backdrop {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 18% 24%, rgba(148, 163, 184, 0.18), transparent 50%),
      radial-gradient(circle at 86% 20%, rgba(96, 165, 250, 0.14), transparent 50%),
      radial-gradient(circle at 30% 82%, rgba(94, 234, 212, 0.12), transparent 46%);
    opacity: 0.45;
  }
</style>

<div class={`luxury-backdrop ${className}`} aria-hidden="true"></div>
