---
const { className = "" } = Astro.props;
---
<style is:global>
  body.luxury-body {
    background:
      linear-gradient(160deg, rgba(248, 250, 252, 0.65), rgba(226, 232, 240, 0.35)),
      url('/assets/img/bg.png') no-repeat center center fixed;
    background-size: cover;
  }

  body.dark-mode.luxury-body {
    background: linear-gradient(160deg, rgba(5, 10, 22, 0.88), rgba(2, 6, 23, 0.92)),
      url('/assets/img/bg.png') no-repeat center center fixed;
    background-size: cover;
  }

  .luxury-backdrop {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(circle at 12% 18%, rgba(125, 211, 252, 0.22), transparent 45%),
      radial-gradient(circle at 88% 22%, rgba(99, 102, 241, 0.18), transparent 48%),
      radial-gradient(circle at 30% 88%, rgba(94, 234, 212, 0.16), transparent 46%);
    opacity: 0.6;
  }
</style>

<div class={`luxury-backdrop ${className}`} aria-hidden="true"></div>
